{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker rm -f pg 2>/dev/null || true && docker volume create hospitality_pgdata >/dev/null && docker run --name pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=hospitality -p 5432:5432 -v hospitality_pgdata:/var/lib/postgresql/data -d postgres:16 && bash -lc 'for i in {1..60}; do docker exec pg pg_isready -U postgres -d hospitality >/dev/null 2>&1 && echo \"pg ready\" && exit 0; sleep 1; done; echo \"pg not ready\"; docker logs --tail 200 pg; exit 1'",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "dev:local": "npm run db:up && npm run db:migrate && npm run db:seed && next dev"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mapbox/mapbox-gl-geocoder": "^5.1.2",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/postcss": "^4.2.1",
    "cloudinary": "^2.9.0",
    "deepmerge": "^4.3.1",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.575.0",
    "mapbox-gl": "^3.19.1",
    "next": "16.1.6",
    "pg": "^8.19.0",
    "pg-connection-string": "^2.11.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "svix": "^1.86.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mapbox__mapbox-gl-geocoder": "^5.1.1",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
