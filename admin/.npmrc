# legacy-peer-deps applies project-wide because:
#
#   inngest@4 declares optional framework-integration peers for every
#   server it ships a serve handler for (h3, hono, koa, fastify, express,
#   @sveltejs/kit, etc.). They are mutually exclusive in any real project
#   and not actually required at runtime — Inngest tree-shakes the unused
#   ones. npm's strict peer resolution treats them as required and refuses
#   the install (e.g. @sveltejs/kit transitively wants vite@8 while
#   vitest@4 pins vite@7).
#
# legacy-peer-deps mirrors npm v6 behavior for THIS project only and is
# the standard escape hatch for poly-framework SDKs. Vercel's plain
# `npm install` honors this file.
legacy-peer-deps=true
