# Bedfront environment variables — example template.
#
# This file documents env vars introduced and consumed by the codebase.
# It is intentionally not exhaustive of the full production environment
# — many legacy vars are managed directly in the Vercel project
# settings. New phases should append their vars here as they introduce
# them, so the file grows into a complete reference over time.
#
# Copy to `.env` (or `.env.local`) and fill in real values for local
# dev. Production values live in Vercel's environment settings.

# ── Phase 1A: Inngest (analytics pipeline + future async workflows) ──
# Both keys are written automatically by the Inngest Vercel integration
# in production / preview. For local dev they are optional — set
# INNGEST_DEV=1 instead and run `npx inngest-cli@latest dev`.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1

# ── Phase 0: Analytics pipeline dev guard ─────────────────────────────
# When set to "1" in development (default), direct access to the
# analytics-pipeline Prisma models (analyticsPipelineEvent /
# analyticsPipelineOutbox / analyticsPipelineTenantConfig) outside of
# `withTenant(...)` throws with a pointer to the helper. Always inert
# in production regardless of value. Set to "0" locally to disable.
ANALYTICS_PIPELINE_DEV_GUARD=1

# ── Phase 1B: Analytics outbox DLQ threshold ──────────────────────────
# Number of consecutive drain failures after which an outbox row is
# marked DLQ and removed from the active queue. The drainer captures
# DLQ rows via Sentry (fingerprint scopes by event_name + error_type
# so repeated DLQs of the same shape group into one issue). Default 5.
ANALYTICS_DLQ_THRESHOLD=5

# ── Dev: Mews demo hotel hookup ───────────────────────────────────────
# When set, `npm run db:seed` connects the dev tenant to the operator's
# private Mews demo property by writing an encrypted TenantIntegration
# row (provider="mews", isDemoEnvironment=true) and pulling the property's
# RoomCategories + units into the local DB. The seed reuses the public
# Mews demo client token; only the per-property accessToken is private
# and lives here. Leave empty to fall back to the synthetic FakeAdapter.
# Never set in production.
DEV_MEWS_DEMO_ACCESS_TOKEN=

# ── Dev: self-healing bootstrap ───────────────────────────────────────
# `npm run dev` runs `npm run dev:bootstrap` first — a fast (~150ms)
# verify-and-heal step that ensures the dev tenant + Mews integration +
# accommodations match the env. Heals automatically if anything has
# drifted (missing tenant, stale accessToken, empty accommodations) by
# re-running `npm run db:seed`. Fast no-op when state is already aligned.
# Use `npm run dev:no-bootstrap` to skip verification (rare).
