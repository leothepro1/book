# Bedfront environment variables — example template.
#
# This file documents env vars introduced and consumed by the codebase.
# It is intentionally not exhaustive of the full production environment
# — many legacy vars are managed directly in the Vercel project
# settings. New phases should append their vars here as they introduce
# them, so the file grows into a complete reference over time.
#
# Copy to `.env` (or `.env.local`) and fill in real values for local
# dev. Production values live in Vercel's environment settings.

# ── Phase 1A: Inngest (analytics pipeline + future async workflows) ──
# Both keys are written automatically by the Inngest Vercel integration
# in production / preview. For local dev they are optional — set
# INNGEST_DEV=1 instead and run `npx inngest-cli@latest dev`.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1

# ── Phase 0: Analytics pipeline dev guard ─────────────────────────────
# When set to "1" in development (default), direct access to the
# analytics-pipeline Prisma models (analyticsPipelineEvent /
# analyticsPipelineOutbox / analyticsPipelineTenantConfig) outside of
# `withTenant(...)` throws with a pointer to the helper. Always inert
# in production regardless of value. Set to "0" locally to disable.
ANALYTICS_PIPELINE_DEV_GUARD=1
