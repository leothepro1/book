{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint -- :*)",
      "Bash(npm run test)",
      "Bash(npm run test -- :*)",
      "Bash(npm run test:watch)",
      "Bash(npm run build)",
      "Bash(npm run build:analytics-runtime)",
      "Bash(npm run start)",
      "Bash(npm run smoke)",
      "Bash(npm run dev)",
      "Bash(npm run dev:clean)",
      "Bash(npm run dev:local)",
      "Bash(npm run db:up)",
      "Bash(npm run db:migrate)",
      "Bash(npm run db:migrate -- :*)",
      "Bash(npm run db:seed)",
      "Bash(npm run pms:export)",
      "Bash(npm run pms:export -- :*)",
      "Bash(npm run pms:import -- :*)",
      "Bash(npm run pms:verify)",
      "Bash(npm run verify:* :*)",
      "Bash(npm run analytics:parity-diff)",
      "Bash(npm run geo:download)",
      "Bash(npm install)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",

      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsx:*)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma format)",
      "Bash(npx prisma migrate status)",
      "Bash(npx prisma migrate dev:*)",
      "Bash(npx prisma migrate deploy)",
      "Bash(npx prisma studio)",
      "Bash(npx prisma validate)",

      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git remote)",
      "Bash(git remote:*)",
      "Bash(git stash)",
      "Bash(git stash:*)",
      "Bash(git fetch)",
      "Bash(git fetch:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git blame:*)",
      "Bash(git check-ignore:*)",
      "Bash(git config --get:*)",

      "Bash(fuser:*)",
      "Bash(lsof:*)",
      "Bash(pgrep:*)",
      "Bash(pkill -f next:*)",
      "Bash(pkill -f turbopack:*)",
      "Bash(pkill -f vitest:*)",
      "Bash(pkill -f next-server:*)",

      "Bash(rm -rf .next)",
      "Bash(rm -rf admin/.next)",
      "Bash(rm -rf node_modules/.cache:*)",
      "Bash(rm -rf .turbo:*)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(env)",
      "Bash(which:*)",
      "Bash(command -v:*)",
      "Bash(type :*)",
      "Bash(test:*)",

      "Bash(mkdir -p:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(touch:*)",
      "Bash(ln -s:*)",

      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(xargs:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(paste:*)",
      "Bash(diff:*)",
      "Bash(comm:*)",

      "Bash(date:*)",
      "Bash(pwd)",
      "Bash(uptime)",
      "Bash(df -h:*)",
      "Bash(du -h:*)",
      "Bash(free -h:*)",
      "Bash(uname:*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(npm --version)",
      "Bash(npm -v)",

      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:www.prisma.io)",
      "WebFetch(domain:stripe.com)",
      "WebFetch(domain:docs.stripe.com)",
      "WebFetch(domain:resend.com)",
      "WebFetch(domain:clerk.com)",
      "WebFetch(domain:upstash.com)",
      "WebFetch(domain:developer.mews.com)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:zod.dev)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:tailwindcss.com)"
    ],

    "deny": [
      "Bash(npx prisma db push:*)",
      "Bash(prisma db push:*)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(prisma migrate reset:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf ..:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard origin/main:*)",
      "Bash(git reset --hard origin/master:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push origin HEAD:main:*)",
      "Bash(git push origin HEAD:master:*)",
      "Bash(curl :* | bash:*)",
      "Bash(curl :* | sh:*)",
      "Bash(wget :* | bash:*)",
      "Bash(wget :* | sh:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./admin/.env)",
      "Read(./admin/.env.*)"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/protected-branch.sh"
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/eslint-post-edit.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/schema-changed.sh"
          }
        ]
      }
    ]
  }
}
