generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum BookingStatus {
  PRE_CHECKIN
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING              // checkout started, payment not yet received
  PAID                 // payment confirmed via webhook
  FULFILLED            // tenant marked as fulfilled
  CANCELLED            // cancelled before or after payment
  PARTIALLY_REFUNDED   // partial refund issued — can be further refunded
  REFUNDED             // full refund issued
}

/// What type of purchase this order represents.
enum OrderType {
  ACCOMMODATION  // PMS booking (hotel room, cabin, camping)
  PURCHASE       // Standard product purchase (shop, gift card, etc.)
}

enum SubscriptionPlan {
  BASIC
  GROW
  PRO
}

enum PaymentSessionStatus {
  INITIATED    // adapter.initiatePayment() called, awaiting customer action
  PENDING      // provider confirmed receipt, async processing
  RESOLVED     // payment succeeded
  REJECTED     // payment failed
  REFUNDED     // full or partial refund completed
}

/// How payment was collected. One value per provider+mode combination.
/// Add new values here when registering a new PaymentAdapter.
enum PaymentMethod {
  STRIPE_CHECKOUT   // @deprecated — use BEDFRONT_PAYMENTS_CHECKOUT
  STRIPE_ELEMENTS   // @deprecated — use BEDFRONT_PAYMENTS_ELEMENTS
  BEDFRONT_PAYMENTS_CHECKOUT  // Stripe Checkout Session via Bedfront Payments
  BEDFRONT_PAYMENTS_ELEMENTS  // Stripe Elements via Bedfront Payments
  SWEDBANK_PAY      // Swedbank Pay (redirect flow)
  NETS              // Nets Easy (redirect flow)
  INVOICE           // Manual invoice
}

/// Lifecycle status of a gift card.
enum GiftCardStatus {
  PENDING    // order paid but delivery not yet executed
  ACTIVE     // ready to send or already sent, not fully redeemed
  REDEEMED   // fully redeemed (balance = 0)
  EXPIRED    // past expiration date (phase 2)
  CANCELLED  // revoked by tenant or refund
}

/// Financial lifecycle — tracks payment state independently of fulfillment.
/// Parallels Shopify's financial_status on orders.
enum OrderFinancialStatus {
  PENDING              // no payment received yet
  AUTHORIZED           // payment authorized but not captured
  PAID                 // payment captured / confirmed
  PARTIALLY_REFUNDED   // partial refund issued
  REFUNDED             // full refund issued
  VOIDED               // authorization voided or session expired
}

/// Fulfillment lifecycle — tracks delivery/service state independently of payment.
/// Parallels Shopify's fulfillment_status on orders.
enum OrderFulfillmentStatus {
  UNFULFILLED   // nothing shipped/delivered yet
  SCHEDULED     // fulfillment scheduled for future date (e.g. check-in date)
  IN_PROGRESS   // partially fulfilled or in transit
  FULFILLED     // fully delivered/completed
  ON_HOLD       // paused (investigation, guest request, etc.)
  CANCELLED     // fulfillment cancelled
}

enum OrderEventType {
  // Order lifecycle
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_UPDATED
  ORDER_CANCELLED
  ORDER_REOPENED

  // Payment — forward
  PAYMENT_AUTHORIZED
  PAYMENT_CAPTURED
  PAYMENT_FAILED
  PAYMENT_VOIDED

  // Payment — backward
  REFUND_INITIATED
  REFUND_SUCCEEDED
  REFUND_FAILED

  // Fulfillment
  ORDER_FULFILLED
  ORDER_UNFULFILLED
  INVENTORY_RELEASED

  // Email
  EMAIL_SENT

  // Internal
  NOTE_ADDED

  // System / diagnostics
  RECONCILED
  GUEST_INFO_UPDATED

  // Sales channel
  CHANNEL_ORDER_RECEIVED    // Order mottagen från extern kanal
  CHANNEL_ORDER_UPDATED     // Order uppdaterad av extern kanal
  CHANNEL_ORDER_CANCELLED   // Order avbokad av extern kanal
  CHANNEL_SYNC_ERROR        // Synkroniseringsfel mot extern kanal

  // Discount
  DISCOUNT_APPLIED
  DISCOUNT_CODE_REDEEMED
  DISCOUNT_REMOVED
}

// ── Guest Account Enums ─────────────────────────────────────────

enum GuestAccountState {
  ENABLED    // active account
  DISABLED   // deactivated by staff
  INVITED    // invitation sent, not yet accepted
  DECLINED   // declined invitation
}

enum GuestMarketingState {
  SUBSCRIBED
  UNSUBSCRIBED
  PENDING
  NOT_SUBSCRIBED
  REDACTED        // GDPR erasure requested
}

enum GuestOptInLevel {
  SINGLE_OPT_IN      // checked a box
  CONFIRMED_OPT_IN   // double opt-in email confirmed
  UNKNOWN
}

enum GuestEventType {
  ACCOUNT_CREATED
  ACCOUNT_UPDATED
  MARKETING_SUBSCRIBED
  MARKETING_UNSUBSCRIBED
  COMMENT_ADDED             // Staff comment in timeline (replaces NOTE_ADDED)
  TAG_ADDED
  TAG_REMOVED
  ORDER_PLACED
  ORDER_PAID
  ORDER_FULFILLED
  ORDER_CANCELLED           // TODO: trigger from cancelOrder() when guest is linked
  ORDER_REFUNDED            // TODO: trigger from refundOrder() when implemented
  LOGIN
  GUEST_EMAIL_SENT          // Email sent to guest (any type)
  DATA_EXPORT_REQUESTED     // TODO: GDPR implementation
  DATA_DELETION_REQUESTED   // TODO: GDPR implementation
  GUEST_JOINED_SEGMENT      // "Gäst gick med i segment: [namn]"
  GUEST_LEFT_SEGMENT        // "Gäst lämnade segment: [namn]"
}

// ── Discount Enums ──────────────────────────────────────────────

enum DiscountMethod {
  AUTOMATIC
  CODE
}

enum DiscountValueType {
  PERCENTAGE   // value field stores basis points: 1500 = 15.00%
  FIXED_AMOUNT // value field stores ören: 10000 = 100 SEK
}

enum DiscountTargetType {
  ORDER      // discount applies to order subtotal
  LINE_ITEM  // discount applies to specific products
}

enum DiscountStatus {
  ACTIVE
  SCHEDULED  // startsAt is in the future
  EXPIRED    // endsAt has passed
  DISABLED   // manually deactivated
}

enum DiscountConditionType {
  // Hospitality-specific
  MIN_NIGHTS       // intValue: minimum number of nights
  DAYS_IN_ADVANCE  // intValue: must book at least N days before arrival
  ARRIVAL_WINDOW   // jsonValue: { startsAt: ISO, endsAt: ISO }
  // Commerce
  MIN_ORDER_AMOUNT // intValue: minimum order total in ören
  MIN_ITEMS        // intValue: minimum item count
  SPECIFIC_PRODUCTS // jsonValue: string[] of productIds
  CUSTOMER_SEGMENT // stringValue: segmentId
  ONCE_PER_CUSTOMER // no value needed — presence means the rule is active
  SPECIFIC_COLLECTIONS // use DiscountCollection join table
  SPECIFIC_CUSTOMERS   // use DiscountCustomer join table
}

enum DiscountEventType {
  CREATED
  UPDATED
  ENABLED
  DISABLED
  CODE_ADDED
  CODE_REMOVED
  USAGE_RECORDED
  USAGE_VOIDED    // discount usage released on order cancel/refund
  NOTE_ADDED      // staff comment on a discount
}

