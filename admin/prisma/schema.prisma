generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum BookingStatus {
  PRE_CHECKIN
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AccessPassType {
  ROOM_KEY
  GATE
  GENERIC
}

enum AccessPassStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
}

enum WalletBackgroundMode {
  SOLID
  GRADIENT
  IMAGE
}

enum AccessPassEventType {
  ISSUED
  REVOKED
  RENDERED_APPLE
  RENDERED_GOOGLE
  RENDER_FAILED
  VALIDATE_ALLOW
  VALIDATE_DENY
}

enum LockProvider {
  fake
  salto
  assa_abloy
  nuki
  manual
}

enum KeyStatus {
  active
  revoked
  expired
}

enum KeyEventType {
  key_created
  key_revoked
  key_expired
  connection_tested
  connection_failed
}

// ============================================================================
// TENANT & BOOKINGS (Organizations-based)
// ============================================================================

model Tenant {
  id        String   @id @default(cuid())
  
  // Clerk Organization mapping (1:1)
  clerkOrgId String  @unique
  
  // Tenant identity
  name      String
  slug      String   @unique

  // Portal subdomain — e.g. "grand-hotel-stockholm-x4k9mq"
  // Generates {name}-{random6}.bedfront.com automatically on creation.
  // Immutable once set. Nullable for backfill of existing tenants.
  portalSlug   String?  @unique
  
  // Owner info (convenience - första admin som skapade org)
  ownerClerkUserId String?
  
  // Tenant configuration (TenantConfig serialized as JSON)
  settings  Json?

  // Draft settings (uncommitted changes for live preview)
  draftSettings  Json?
  draftUpdatedAt DateTime?
  draftUpdatedBy String?  // Clerk userId som senast editerade draft

  /// Optimistic locking — increments on every publish.
  /// Prevents concurrent publish from silently overwriting each other.
  settingsVersion Int @default(0)

  /// Snapshot of settings before last publish — enables one-click rollback.
  previousSettings Json?

  // Företagsinformation (Clerk äger namn/slug/logo — dessa är kompletterande)
  legalName          String?
  businessType       String?
  nickname           String?
  phone              String?

  // Adress
  addressStreet      String?
  addressPostalCode  String?
  addressCity        String?
  addressCountry     String?

  // Statliga ID-handlingar
  organizationNumber String?
  vatNumber          String?

  // Email sender identity
  emailFrom             String?   // e.g. "noreply@grandhotel.se"
  emailFromName         String?   // e.g. "Grand Hotel"

  // Email sender verification — pending change until confirmed via token
  pendingEmailFrom        String?
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?
  emailVerificationSentTo String?

  // Email branding — logo and accent color injected into all templates
  emailLogoUrl          String?   // Cloudinary URL
  emailLogoWidth        Int?      // Logo width in px (default 120)
  emailAccentColor      String?   // hex e.g. "#1A56DB"

  // Feature toggles — account-level, immediate effect (not draft/publish)
  checkinEnabled        Boolean @default(false)
  checkoutEnabled       Boolean @default(false)
  earlyCheckinEnabled   Boolean @default(false)
  earlyCheckinDays      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings           Booking[]
  walletCardDesign   WalletCardDesign?
  mediaAssets        MediaAsset[]
  integration        TenantIntegration?
  syncJobs           SyncJob[]
  syncEvents         SyncEvent[]
  businessEntities   BusinessEntity[]
  policies           TenantPolicy[]
  lockIntegration    TenantLockIntegration?
  locales            TenantLocale[]
  translations       TenantTranslation[]
  emailTemplates     EmailTemplate[]
  emailSendLogs      EmailSendLog[]
  emailUnsubscribes  EmailUnsubscribe[]
  emailDomains       EmailDomain[]
  magicLinkTokens    MagicLinkToken[]

  @@index([slug])
  @@index([clerkOrgId])
}

/// Tenant-scoped policy documents (booking terms, house rules, etc.).
/// Each policy is identified by a stable string ID (e.g. "booking-terms").
/// Lookup: unique constraint on [tenantId, policyId] for fast retrieval.
model TenantPolicy {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Stable identifier — matches POLICY_ITEMS[].id in the frontend.
  /// Values: "booking-terms", "checkin-terms", "house-rules",
  ///         "privacy-policy", "terms-of-service"
  policyId  String

  /// The policy content as plain text (authored by the tenant).
  content   String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, policyId])
  @@index([tenantId])
}

/// Juridisk person / företagsenhet kopplad till en organisation.
/// En tenant kan ha flera företagsenheter (t.ex. hotell + restaurang).
model BusinessEntity {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  businessType      String
  legalName         String
  nickname          String?

  addressStreet     String?
  addressApartment  String?
  addressPostalCode String?
  addressCity       String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
}

model Booking {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // PMS integration — links local booking to external PMS counterpart
  // null for ManualAdapter tenants (existing rows unaffected)
  externalId      String?    @unique
  externalSource  String?
  lastSyncedAt    DateTime?

  // Guest identity
  firstName  String
  lastName   String
  guestEmail String
  phone      String?

  // Address
  street     String?
  postalCode String?
  city       String?
  country    String?

  // Stay
  arrival      DateTime
  departure    DateTime
  unit         String
  status       BookingStatus @default(PRE_CHECKIN)
  checkedInAt  DateTime?
  checkedOutAt DateTime?

  // Digital signature
  signatureCapturedAt DateTime?
  signatureDataUrl    String?   @db.Text

  // Portal access — stable URL-safe token for guest portal links.
  // Generated once on booking creation, never changes.
  portalToken  String?  @unique

  // Email dedup — timestamps prevent duplicate notification emails
  // during repeated sync cycles. Null = email not yet sent.
  confirmedEmailSentAt  DateTime?
  checkedInEmailSentAt  DateTime?
  checkedOutEmailSentAt DateTime?

  magicLinks   MagicLink[]
  accessPasses AccessPass[]
  createdAt    DateTime    @default(now())

  @@index([tenantId])
  @@index([guestEmail])
  @@index([status])
  @@index([arrival])
  @@index([tenantId, externalId])
}

model MagicLink {
  id        String   @id @default(cuid())
  token     String   @unique
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([bookingId])
}

// ============================================================================
// ACCESS PASSES (Hotellkort / Wallet Passes)
// ============================================================================

/// A canonical access credential tied to a booking.
/// Can be rendered to Apple/Google Wallet via adapter layer.
/// Token is NEVER stored in cleartext — only SHA-256 hash + pepper.
model AccessPass {
  id       String @id @default(cuid())
  tenantId String

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  /// Denormalized for admin filtering — always matches booking.guestEmail
  guestId   String

  type      AccessPassType

  /// Persisted status. UI should use computeEffectiveStatus() which also
  /// considers validFrom/validTo and revokedAt at query time.
  status    AccessPassStatus @default(PENDING)

  /// Activation window — pass is only ACTIVE within this range
  validFrom DateTime
  validTo   DateTime

  /// Revocation data (kill switch)
  revokedAt        DateTime?
  revokedByUserId  String?
  revokeReason     String?

  /// Globally unique external identifier (safe to expose in URLs/QR codes)
  serial    String @unique

  /// SHA-256(tokenRaw + pepper). tokenRaw is returned ONCE at issuance and never stored.
  tokenHash String @unique

  /// Last 4 chars of tokenRaw — for support identification only
  tokenLast4 String

  /// Optimistic locking — increment on every mutation
  version   Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    AccessPassEvent[]

  /// Hard constraint: one pass per booking per type. Prevents duplicates
  /// even under concurrent requests (DB-level enforcement).
  @@unique([tenantId, bookingId, type])

  @@index([tenantId])
  @@index([bookingId])
  @@index([guestId])
  @@index([tenantId, status])
  @@index([tenantId, guestId])
  @@index([validTo])
}

/// Immutable audit log for every access pass state change.
/// Never deleted, never updated — append-only.
model AccessPassEvent {
  id       String @id @default(cuid())
  tenantId String

  passId   String
  pass     AccessPass @relation(fields: [passId], references: [id])

  type     AccessPassEventType

  /// Who triggered this event (null for system/automated events)
  actorUserId String?

  /// Request context (nullable — not always available)
  ip        String?
  userAgent String?

  /// Arbitrary structured data (e.g. renderer output, deny reason)
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([passId])
  @@index([tenantId, passId])
  @@index([type])
}

// ============================================================================
// PMS INTEGRATION (Per-tenant PMS connection config)
// ============================================================================

/// Stores per-tenant PMS integration credentials and state.
/// Credentials are AES-256-GCM encrypted — never stored in cleartext.
/// Separate from TenantConfig (which is sent to the editor frontend).
model TenantIntegration {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  provider             String
  credentialsEncrypted Bytes
  credentialsIv        Bytes
  status               String    @default("pending")
  lastSyncAt           DateTime?
  lastErrorAt          DateTime?
  lastError            String?
  consecutiveFailures  Int       @default(0)
  externalTenantId     String?
  isDemoEnvironment    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([provider, externalTenantId])
}

// ============================================================================
// SYNC JOBS (Background PMS sync queue)
// ============================================================================

/// Queue entry for a background PMS sync operation.
/// Processed one at a time by the job runner API route.
/// Failed jobs are retried with exponential backoff up to maxAttempts.
model SyncJob {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider     String
  status       String    @default("pending")
  attempt      Int       @default(0)
  maxAttempts  Int       @default(5)
  scheduledAt  DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  failedAt     DateTime?
  lastError    String?
  payload      Json?
  createdAt    DateTime  @default(now())

  @@index([tenantId, status])
  @@index([scheduledAt, status])
}

// ============================================================================
// SYNC EVENTS (Immutable audit trail for PMS sync operations)
// ============================================================================

/// Immutable audit log for all PMS sync activity.
/// Never deleted, never updated — append-only.
/// Types: booking.created, booking.updated, booking.cancelled,
///        sync.started, sync.completed, sync.failed,
///        connection.tested, connection.failed
model SyncEvent {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider          String
  eventType         String
  bookingExternalId String?
  payload           Json?
  error             String?
  createdAt         DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, eventType])
}

// ============================================================================
// RATE LIMIT (Database-backed per-AccessToken rate limiter)
// ============================================================================

/// Token bucket rate limiter backed by the database.
/// Key is a hashed AccessToken — never stores the raw token.
/// Used by PMS adapters to respect external API rate limits
/// across serverless invocations.
model RateLimit {
  id         String   @id @default(cuid())
  key        String   @unique
  tokens     Float    @default(200)
  lastRefill DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================================
// BOOKING SYNC ERRORS (Dead letter for individual booking failures)
// ============================================================================

/// Tracks individual booking sync failures for retry.
/// Retried at the start of each sync job (up to 5 attempts).
/// Resolved entries cleaned up after 30 days.
model BookingSyncError {
  id            String    @id @default(cuid())
  tenantId      String
  provider      String
  externalId    String
  error         String
  attempts      Int       @default(1)
  lastAttemptAt DateTime  @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@unique([tenantId, externalId])
  @@index([tenantId, resolvedAt])
}

// ============================================================================
// WEBHOOK DEDUP (PMS integration webhook idempotency)
// ============================================================================

/// Database-level unique constraint for PMS webhook deduplication.
/// The dedupKey is a composite of provider + webhook event ID.
/// Entries older than 7 days are cleaned up by the poller.
model WebhookDedup {
  id        String   @id @default(cuid())
  dedupKey  String   @unique
  provider  String
  tenantId  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ============================================================================
// WEBHOOK IDEMPOTENCY (Clerk webhooks)
// ============================================================================

/// Tracks processed Clerk webhook events to ensure idempotency.
/// Before processing any event, check if svix-id already exists.
/// If yes, return 200 immediately (already handled).
model WebhookEvent {
  id          String   @id                    // svix-id from webhook header
  eventType   String
  processedAt DateTime @default(now())

  @@index([id])
}

// ============================================================================
// WALLET CARD DESIGN (Per-tenant card styling for Apple/Google Wallet)
// ============================================================================

// ============================================================================
// MEDIA ASSETS (Organization-scoped media library)
// ============================================================================

/// Persistent media index. Cloudinary is source of truth for files,
/// this table is source of truth for indexing, ownership, and permissions.
/// Supports soft-delete with delayed Cloudinary cleanup.
model MediaAsset {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // ── Cloudinary identity ─────────────────────────────────────────
  /// Full Cloudinary public_id (e.g. "hospitality/acme-hotel/cards/abc123")
  publicId  String @unique
  /// Optimized delivery URL (secure_url from upload response)
  url       String
  /// Cloudinary resource type ("image", "video", "raw")
  resourceType String @default("image")

  // ── File metadata ───────────────────────────────────────────────
  /// Original filename from upload (user-facing)
  filename   String
  /// MIME type (image/jpeg, image/png, etc.)
  mimeType   String
  /// File size in bytes
  bytes      Int
  /// Image dimensions (null for non-image resources)
  width      Int?
  height     Int?
  /// Cloudinary format (jpg, png, webp, etc.)
  format     String

  // ── Organization ────────────────────────────────────────────────
  /// Logical folder within the tenant (cards, wallpaper, sections, etc.)
  folder     String @default("general")
  /// User-editable alt text for accessibility
  alt        String @default("")
  /// User-editable title/caption
  title      String @default("")

  // ── Provenance ──────────────────────────────────────────────────
  /// Clerk userId who uploaded this asset
  uploadedBy String

  // ── Soft delete ─────────────────────────────────────────────────
  /// Null = active. Set = soft-deleted (pending Cloudinary cleanup).
  deletedAt  DateTime?
  /// Who deleted it
  deletedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Indexes ─────────────────────────────────────────────────────
  @@index([tenantId])
  @@index([tenantId, folder])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, mimeType])
  @@index([deletedAt])  // For cleanup job: find soft-deleted assets
}

/// Visual design template for wallet passes. One per tenant.
/// Controls background, logo placement, and date text styling.
/// All passes issued by this tenant inherit these settings.
model WalletCardDesign {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // ── Background ────────────────────────────────────────────────────
  backgroundMode           WalletBackgroundMode @default(SOLID)
  /// Hex color for SOLID and GRADIENT base color
  backgroundColor          String?
  /// Gradient direction: "up" or "down" (matches guest portal theme)
  gradientDirection        String?              @default("down")
  /// Image URL for IMAGE mode
  backgroundImageUrl       String?
  /// Dark overlay opacity for IMAGE mode (0..1)
  overlayOpacity           Float?               @default(0.3)

  // ── Logo ──────────────────────────────────────────────────────────
  /// Logo image displayed top-left on the card
  logoUrl                  String?

  // ── Date text ─────────────────────────────────────────────────────
  /// Text color for the check-in/check-out date range (top-right)
  dateTextColor            String             @default("#ffffff")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// DIGITAL KEY INTEGRATION
// ============================================================================

/// Lock system integration per tenant (1:1).
/// Follows same pattern as TenantIntegration for PMS.
model TenantLockIntegration {
  id                   String       @id @default(cuid())
  tenantId             String       @unique
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  provider             LockProvider
  credentialsEncrypted Bytes?
  credentialsIv        Bytes?
  status               String       @default("pending") // active | disconnected | error | pending
  consecutiveFailures  Int          @default(0)
  lastTestedAt         DateTime?
  lastError            String?

  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  digitalKeys          DigitalKey[]
  keyEvents            KeyEvent[]
}

/// A digital key issued to a guest for a specific booking.
/// One active key per booking per tenant.
model DigitalKey {
  id             String    @id @default(cuid())
  tenantId       String
  bookingId      String
  integrationId  String
  integration    TenantLockIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  keyId          String    // External ID at lock provider
  provider       LockProvider
  status         KeyStatus @default(active)
  validFrom      DateTime
  validTo        DateTime
  walletPayload  Json
  portalPayload  Json

  revokedAt      DateTime?
  revokedBy      String?   // userId who revoked

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  events         KeyEvent[]

  @@unique([tenantId, bookingId])
  @@index([tenantId, status])
}

/// Append-only event log for digital key lifecycle.
model KeyEvent {
  id            String    @id @default(cuid())
  tenantId      String
  integrationId String
  integration   TenantLockIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  keyId         String?
  key           DigitalKey? @relation(fields: [keyId], references: [id], onDelete: SetNull)
  bookingId     String?
  eventType     KeyEventType
  metadata      Json?
  createdAt     DateTime  @default(now())
}

// ============================================================================
// TRANSLATIONS
// ============================================================================

enum EmailSendStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  COMPLAINED
  FAILED
}

enum EmailEventType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  CHECK_IN_CONFIRMED
  CHECK_OUT_CONFIRMED
  MAGIC_LINK
  SUPPORT_REPLY
}

enum TranslationNamespace {
  PLATFORM
  TENANT
  LOCKED
}

model TenantLocale {
  id         String   @id @default(cuid())
  tenantId   String
  locale     String   // BCP-47: "en", "de", "fr", "sv" etc.
  published  Boolean  @default(false)
  primary    Boolean  @default(false) // only one per tenant
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  translations TenantTranslation[]

  @@unique([tenantId, locale])
  @@index([tenantId, published])
}

model TenantTranslation {
  id           String               @id @default(cuid())
  tenantId     String
  locale       String
  resourceId   String               // ResourceId branded string
  namespace    TranslationNamespace
  value             String               // published value — what guests see
  draftValue        String?              // unpublished value — null means no pending draft
  sourceDigest      String               // digest of source when value was published
  draftSourceDigest String?              // digest of source when draftValue was saved
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantLocale TenantLocale @relation(fields: [tenantId, locale], references: [tenantId, locale], onDelete: Cascade)

  @@unique([tenantId, locale, resourceId])
  @@index([tenantId, locale])
  @@index([tenantId, resourceId])
}

// ============================================================================
// EMAIL TEMPLATES (Per-tenant email notification overrides)
// ============================================================================

/// Per-tenant email template overrides. Null content fields mean
/// "use platform default" from the email event registry.
/// One row per tenant per event type — unique constraint enforced.
model EmailTemplate {
  id          String         @id @default(cuid())
  tenantId    String
  eventType   EmailEventType

  /// Null = use platform default subject
  subject     String?
  /// Null = use platform default preview text
  previewText String?
  /// Null = use platform default HTML (from react-email components)
  html        String?        @db.Text

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eventType])
  @@index([tenantId])
}

// ============================================================================
// EMAIL SEND LOG (Append-only audit trail for all outgoing emails)
// ============================================================================

/// One row per send attempt through sendEmailEvent().
/// Updated by Resend webhooks as delivery status progresses.
model EmailSendLog {
  id          String          @id @default(cuid())
  tenantId    String
  eventType   EmailEventType
  toEmail     String
  resendId    String?         // Resend's message ID, set after successful send
  status      EmailSendStatus @default(QUEUED)
  error       String?         // error message if status = FAILED
  sentAt      DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([resendId])
  @@index([toEmail])
  @@index([tenantId, eventType])
}

// ============================================================================
// EMAIL UNSUBSCRIBE (Per-tenant opt-out registry)
// ============================================================================

/// Stores opt-out per email address per tenant. Once a record exists,
/// no further emails are sent to that address from that tenant.
model EmailUnsubscribe {
  id              String   @id @default(cuid())
  tenantId        String
  email           String
  unsubscribedAt  DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

// ============================================================================
// EMAIL DOMAINS (Per-tenant sender domain verification via Resend)
// ============================================================================

enum EmailDomainStatus {
  PENDING     // added, DNS not yet configured
  VERIFIED    // Resend confirmed DNS records are correct
  FAILED      // verification failed
}

/// Per-tenant sender domain. Once verified, emails are sent from
/// noreply@[domain] instead of onboarding@resend.dev.
model EmailDomain {
  id              String            @id @default(cuid())
  tenantId        String
  domain          String            // e.g. "grandhotel.se"
  resendDomainId  String?           // Resend's domain ID after creation
  status          EmailDomainStatus @default(PENDING)
  dnsRecords      Json?             // DNS records returned by Resend
  verifiedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, domain])
  @@index([tenantId])
}

// ============================================================================
// MAGIC LINK TOKENS (Guest portal email-based authentication)
// ============================================================================

/// Email-based magic link tokens for guest portal authentication.
/// Not booking-scoped — a guest authenticates with email, then sees
/// all bookings for that email address on the tenant.
/// Tokens are single-use, time-limited, and rate-limited per email.
model MagicLinkToken {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tenantId, email])
  @@index([expiresAt])
}

// ============================================================================
// EMAIL RATE LIMITING (Per-recipient per-event-type throttle)
// ============================================================================

/// Append-only send log for rate limiting.
/// We count rows in a rolling time window rather than maintaining counters.
/// Simple, debuggable, no update races.
/// Cleaned up daily by /api/integrations/cleanup.
model EmailRateLimit {
  id        String         @id @default(cuid())
  tenantId  String
  email     String
  eventType EmailEventType
  sentAt    DateTime       @default(now())

  @@index([tenantId, email, eventType, sentAt])
}
