generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum BookingStatus {
  PRE_CHECKIN
  ACTIVE
  COMPLETED
}

// ============================================================================
// TENANT & BOOKINGS (Organizations-based)
// ============================================================================

model Tenant {
  id        String   @id @default(cuid())
  
  // Clerk Organization mapping (1:1)
  clerkOrgId String  @unique
  
  // Tenant identity
  name      String
  slug      String   @unique
  
  // Owner info (convenience - första admin som skapade org)
  ownerClerkUserId String?
  
  // Tenant configuration (TenantConfig serialized as JSON)
  settings  Json?

  // Draft settings (uncommitted changes for live preview)
  draftSettings  Json?
  draftUpdatedAt DateTime?
  draftUpdatedBy String?  // Clerk userId som senast editerade draft
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([slug])
  @@index([clerkOrgId])
}

model Booking {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Guest identity
  firstName  String
  lastName   String
  guestEmail String
  phone      String?

  // Address
  street     String?
  postalCode String?
  city       String?
  country    String?

  // Stay
  arrival      DateTime
  departure    DateTime
  unit         String
  status       BookingStatus @default(PRE_CHECKIN)
  checkedInAt  DateTime?
  checkedOutAt DateTime?

  // Digital signature
  signatureCapturedAt DateTime?
  signatureDataUrl    String?   @db.Text

  magicLinks MagicLink[]
  createdAt  DateTime    @default(now())

  @@index([tenantId])
  @@index([guestEmail])
  @@index([status])
  @@index([arrival])
}

model MagicLink {
  id        String   @id @default(cuid())
  token     String   @unique
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([bookingId])
}
