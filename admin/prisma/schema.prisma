/// Idempotency lock for PMS booking creation.
/// Prevents duplicate concurrent bookings for the same dates/guest.
/// Cleaned up by the expire-reservations cron.
model PendingBookingLock {
  key        String   @id
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([expiresAt])
}

// ============================================================================
// TENANT & BOOKINGS (Organizations-based)
// ============================================================================

model Tenant {
  id        String   @id @default(cuid())
  
  // Clerk Organization mapping (1:1)
  clerkOrgId String  @unique
  
  // Tenant identity
  name      String
  slug      String   @unique

  // Portal subdomain — e.g. "grand-hotel-stockholm-x4k9mq"
  // Generates {name}-{random6}.rutgr.com automatically on creation.
  // Immutable once set. Nullable for backfill of existing tenants.
  portalSlug   String?  @unique
  
  // Owner info (convenience - första admin som skapade org)
  ownerClerkUserId String?
  
  // Tenant configuration (TenantConfig serialized as JSON)
  settings  Json?

  // Draft settings (uncommitted changes for live preview)
  draftSettings  Json?
  draftUpdatedAt DateTime?
  draftUpdatedBy String?  // Clerk userId som senast editerade draft

  /// Optimistic locking — increments on every publish.
  /// Prevents concurrent publish from silently overwriting each other.
  settingsVersion Int @default(0)

  /// Snapshot of settings before last publish — enables one-click rollback.
  previousSettings Json?

  // Företagsinformation (Clerk äger namn/slug/logo — dessa är kompletterande)
  legalName          String?
  businessType       String?
  nickname           String?
  phone              String?

  // Adress
  addressStreet      String?
  addressPostalCode  String?
  addressCity        String?
  addressCountry     String?

  // Statliga ID-handlingar
  organizationNumber String?
  vatNumber          String?

  // Email sender identity
  emailFrom             String?   // e.g. "noreply@grandhotel.se"
  emailFromName         String?   // e.g. "Grand Hotel"

  // Email sender verification — pending change until confirmed via token
  pendingEmailFrom        String?
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?
  emailVerificationSentTo String?

  // Email branding — logo and accent color injected into all templates
  emailLogoUrl          String?   // Cloudinary URL
  emailLogoWidth        Int?      // Logo width in px (default 120)
  emailAccentColor      String?   // hex e.g. "#1A56DB"

  // Feature toggles — account-level, immediate effect (not draft/publish)
  // Order number formatting — Shopify-style prefix/suffix
  orderNumberPrefix     String  @default("")
  orderNumberSuffix     String  @default("")

  checkinEnabled        Boolean @default(false)
  checkoutEnabled       Boolean @default(false)
  earlyCheckinEnabled   Boolean @default(false)
  earlyCheckinDays      Int     @default(0)

  // Theme screenshot — generated asynchronously after publish
  screenshotDesktopUrl  String?               // Cloudinary URL, desktop (1440×900)
  screenshotMobileUrl   String?               // Cloudinary URL, mobile (390×844)
  screenshotHash        String?               // SHA-256 content-hash of settings JSON
  screenshotUpdatedAt   DateTime?             // When last screenshot was taken
  screenshotPending     Boolean @default(false) // Job queued for screenshot generation

  // Stripe Connect — each tenant connects their OWN Stripe account
  stripeAccountId          String?   // acct_xxx — connected Stripe account ID
  stripeOnboardingComplete Boolean   @default(false)
  stripeLivemode           Boolean   @default(false)
  stripeConnectedAt        DateTime?
  paymentMethodConfig      Json?     // PaymentMethodConfig — which methods tenant has enabled

  // Subscription & platform fee
  subscriptionPlan         SubscriptionPlan @default(BASIC)
  platformFeeBps           Int?             // basis points override per tenant, null = use plan default

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings           Booking[]
  mediaAssets        MediaAsset[]
  integration        TenantIntegration?
  syncJobs           SyncJob[]
  syncEvents         SyncEvent[]
  businessEntities   BusinessEntity[]
  policies           TenantPolicy[]
  locales            TenantLocale[]
  translations       TenantTranslation[]
  emailTemplates     EmailTemplate[]
  emailSendLogs      EmailSendLog[]
  emailUnsubscribes  EmailUnsubscribe[]
  emailDomains       EmailDomain[]
  magicLinkTokens    MagicLinkToken[]
  guestAccounts      GuestAccount[]
  products           Product[]
  productTemplates   ProductTemplate[]
  productCollections ProductCollection[]
  orders              Order[]
  giftCardProducts    GiftCardProduct[]
  giftCards           GiftCard[]
  paymentSessions     PaymentSession[]
  paymentConfig       TenantPaymentConfig?
  apps                TenantApp[]
  billingSettings     TenantBillingSettings?
  channelPublications ProductChannelPublication[]
  guestTags           GuestTag[]
  guestNotes          GuestNote[]
  guestEvents         GuestAccountEvent[]
  guestAddresses      GuestAddress[]
  guestSegments       GuestSegment[]
  rumEvents           RumEvent[]
  rumAggregates       RumDailyAggregate[]
  rumRateLimit        RumRateLimit?
  analyticsEvents     AnalyticsEvent[]
  analyticsMetrics    AnalyticsDailyMetric[]
  discounts           Discount[]
  accommodations      Accommodation[]
  accommodationCategories AccommodationCategory[]
  spotMaps            SpotMap[]
  spotMarkers         SpotMarker[]
  emailAppInstallation  EmailAppInstallation?
  emailAppTemplates     EmailAppTemplate[]
  emailCampaigns        EmailCampaign[]
  emailAutomations      EmailAutomation[]
  emailSuppressions     EmailSuppression[]

  // Feature toggle — tenant can disable all discount functionality
  discountsEnabled    Boolean              @default(true)

  @@index([slug])
  @@index([clerkOrgId])
}

/// Tenant-scoped policy documents (booking terms, house rules, etc.).
/// Each policy is identified by a stable string ID (e.g. "booking-terms").
/// Lookup: unique constraint on [tenantId, policyId] for fast retrieval.
model TenantPolicy {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Stable identifier — matches POLICY_ITEMS[].id in the frontend.
  /// Values: "booking-terms", "checkin-terms", "house-rules",
  ///         "privacy-policy", "terms-of-service"
  policyId  String

  /// The policy content as plain text (authored by the tenant).
  content   String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, policyId])
  @@index([tenantId])
}

/// Juridisk person / företagsenhet kopplad till en organisation.
/// En tenant kan ha flera företagsenheter (t.ex. hotell + restaurang).
model BusinessEntity {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  businessType      String
  legalName         String
  nickname          String?

  addressStreet     String?
  addressApartment  String?
  addressPostalCode String?
  addressCity       String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
}

model Booking {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // PMS integration — links local booking to external PMS counterpart
  // null for ManualAdapter tenants (existing rows unaffected)
  externalId      String?    @unique
  externalSource  String?
  lastSyncedAt    DateTime?

  // Guest identity
  firstName  String
  lastName   String
  guestEmail String
  phone      String?

  // Address
  street     String?
  postalCode String?
  city       String?
  country    String?

  // Stay
  arrival      DateTime
  departure    DateTime
  unit         String
  status       BookingStatus @default(PRE_CHECKIN)
  checkedInAt  DateTime?
  checkedOutAt DateTime?

  // Digital signature
  signatureCapturedAt DateTime?
  signatureDataUrl    String?   @db.Text
  checkinData         Json?

  // Portal access — stable URL-safe token for guest portal links.
  // Generated once on booking creation, never changes.
  portalToken  String?  @unique

  // Email dedup — timestamps prevent duplicate notification emails
  // during repeated sync cycles. Null = email not yet sent.
  confirmedEmailSentAt  DateTime?
  checkedInEmailSentAt  DateTime?
  checkedOutEmailSentAt DateTime?

  // Guest account link — set during sync when guest email is valid
  guestAccountId String?
  guestAccount   GuestAccount? @relation(fields: [guestAccountId], references: [id], onDelete: SetNull)

  // ── Accommodation infrastructure (added for first-class accommodation model) ──
  // Optional during migration — will be made required after data backfill.
  accommodationId String?  // FK → Accommodation
  orderId         String?  // FK → Order
  ratePlanId      String?  // which rate plan was booked
  checkIn         DateTime? // canonical check-in (replaces arrival after migration)
  checkOut        DateTime? // canonical check-out (replaces departure after migration)
  guestCount      Int?
  specialRequests String?  @db.Text
  pmsBookingRef   String?  // PMS confirmation number (kept alongside externalId during migration)

  accommodation   Accommodation? @relation(fields: [accommodationId], references: [id])
  order           Order?         @relation(fields: [orderId], references: [id])

  magicLinks   MagicLink[]
  createdAt    DateTime    @default(now())

  @@index([tenantId])
  @@index([guestEmail])
  @@index([status])
  @@index([arrival])
  @@index([tenantId, externalId])
  @@index([tenantId, guestEmail])
  @@index([tenantId, guestAccountId])
  @@index([accommodationId])
  @@index([orderId])
  @@index([tenantId, accommodationId])
}

model MagicLink {
  id        String   @id @default(cuid())
  token     String   @unique
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([bookingId])
}

// ============================================================================
// PMS INTEGRATION (Per-tenant PMS connection config)
// ============================================================================

/// Stores per-tenant PMS integration credentials and state.
/// Credentials are AES-256-GCM encrypted — never stored in cleartext.
/// Separate from TenantConfig (which is sent to the editor frontend).
model TenantIntegration {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  provider             String
  credentialsEncrypted Bytes
  credentialsIv        Bytes
  status               String    @default("pending")
  lastSyncAt           DateTime?
  lastErrorAt          DateTime?
  lastError            String?
  consecutiveFailures  Int       @default(0)
  externalTenantId     String?
  isDemoEnvironment    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([provider, externalTenantId])
}

// ============================================================================
// SYNC JOBS (Background PMS sync queue)
// ============================================================================

/// Queue entry for a background PMS sync operation.
/// Processed one at a time by the job runner API route.
/// Failed jobs are retried with exponential backoff up to maxAttempts.
model SyncJob {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider     String
  status       String    @default("pending")
  attempt      Int       @default(0)
  maxAttempts  Int       @default(5)
  scheduledAt  DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  failedAt     DateTime?
  lastError    String?
  payload      Json?
  createdAt    DateTime  @default(now())

  @@index([tenantId, status])
  @@index([scheduledAt, status])
}

// ============================================================================
// SYNC EVENTS (Immutable audit trail for PMS sync operations)
// ============================================================================

/// Immutable audit log for all PMS sync activity.
/// Never deleted, never updated — append-only.
/// Types: booking.created, booking.updated, booking.cancelled,
///        sync.started, sync.completed, sync.failed,
///        connection.tested, connection.failed
model SyncEvent {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider          String
  eventType         String
  bookingExternalId String?
  payload           Json?
  error             String?
  createdAt         DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, eventType])
}

// ============================================================================
// RATE LIMIT (Database-backed per-AccessToken rate limiter)
// ============================================================================

/// Token bucket rate limiter backed by the database.
/// Key is a hashed AccessToken — never stores the raw token.
/// Used by PMS adapters to respect external API rate limits
/// across serverless invocations.
model RateLimit {
  id         String   @id @default(cuid())
  key        String   @unique
  tokens     Float    @default(200)
  lastRefill DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================================
// BOOKING SYNC ERRORS (Dead letter for individual booking failures)
// ============================================================================

/// Tracks individual booking sync failures for retry.
/// Retried at the start of each sync job (up to 5 attempts).
/// Resolved entries cleaned up after 30 days.
model BookingSyncError {
  id            String    @id @default(cuid())
  tenantId      String
  provider      String
  externalId    String
  error         String
  attempts      Int       @default(1)
  lastAttemptAt DateTime  @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@unique([tenantId, externalId])
  @@index([tenantId, resolvedAt])
}

// ============================================================================
// WEBHOOK DEDUP (PMS integration webhook idempotency)
// ============================================================================

/// Database-level unique constraint for PMS webhook deduplication.
/// The dedupKey is a composite of provider + webhook event ID.
/// Entries older than 7 days are cleaned up by the poller.
model WebhookDedup {
  id        String   @id @default(cuid())
  dedupKey  String   @unique
  provider  String
  tenantId  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ============================================================================
// WEBHOOK IDEMPOTENCY (Clerk webhooks)
// ============================================================================

/// Tracks processed Clerk webhook events to ensure idempotency.
/// Before processing any event, check if svix-id already exists.
/// If yes, return 200 immediately (already handled).
model WebhookEvent {
  id          String   @id                    // svix-id from webhook header
  eventType   String
  processedAt DateTime @default(now())

  @@index([id])
}

// ============================================================================
// MEDIA ASSETS (Organization-scoped media library)
// ============================================================================

/// Persistent media index. Cloudinary is source of truth for files,
/// this table is source of truth for indexing, ownership, and permissions.
/// Supports soft-delete with delayed Cloudinary cleanup.
model MediaAsset {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // ── Cloudinary identity ─────────────────────────────────────────
  /// Full Cloudinary public_id (e.g. "hospitality/acme-hotel/cards/abc123")
  publicId  String @unique
  /// Optimized delivery URL (secure_url from upload response)
  url       String
  /// Cloudinary resource type ("image", "video", "raw")
  resourceType String @default("image")

  // ── File metadata ───────────────────────────────────────────────
  /// Original filename from upload (user-facing)
  filename   String
  /// MIME type (image/jpeg, image/png, etc.)
  mimeType   String
  /// File size in bytes
  bytes      Int
  /// Image dimensions (null for non-image resources)
  width      Int?
  height     Int?
  /// Cloudinary format (jpg, png, webp, etc.)
  format     String

  // ── Organization ────────────────────────────────────────────────
  /// Logical folder within the tenant (cards, wallpaper, sections, etc.)
  folder     String @default("general")
  /// User-editable alt text for accessibility
  alt        String @default("")
  /// User-editable title/caption
  title      String @default("")

  // ── Provenance ──────────────────────────────────────────────────
  /// Clerk userId who uploaded this asset
  uploadedBy String

  // ── Soft delete ─────────────────────────────────────────────────
  /// Null = active. Set = soft-deleted (pending Cloudinary cleanup).
  deletedAt  DateTime?
  /// Who deleted it
  deletedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Indexes ─────────────────────────────────────────────────────
  @@index([tenantId])
  @@index([tenantId, folder])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, mimeType])
  @@index([deletedAt])  // For cleanup job: find soft-deleted assets
}

// ============================================================================
// TRANSLATIONS
// ============================================================================

enum EmailSendStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  COMPLAINED
  FAILED
  PERMANENTLY_FAILED
}

enum EmailEventType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  CHECK_IN_CONFIRMED
  CHECK_OUT_CONFIRMED
  MAGIC_LINK
  SUPPORT_REPLY
  GUEST_OTP
  ORDER_CONFIRMED
  GIFT_CARD_SENT
  PAYMENT_FAILED
  ABANDONED_CHECKOUT
  PRE_ARRIVAL_REMINDER
  POST_STAY_FEEDBACK
  MARKETING_OPT_IN_CONFIRM
}

enum TranslationNamespace {
  PLATFORM
  TENANT
  LOCKED
}

model TenantLocale {
  id         String   @id @default(cuid())
  tenantId   String
  locale     String   // BCP-47: "en", "de", "fr", "sv" etc.
  published  Boolean  @default(false)
  primary    Boolean  @default(false) // only one per tenant
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  translations TenantTranslation[]

  @@unique([tenantId, locale])
  @@index([tenantId, published])
}

model TenantTranslation {
  id           String               @id @default(cuid())
  tenantId     String
  locale       String
  resourceId   String               // ResourceId branded string
  namespace    TranslationNamespace
  value             String               // published value — what guests see
  draftValue        String?              // unpublished value — null means no pending draft
  sourceDigest      String               // digest of source when value was published
  draftSourceDigest String?              // digest of source when draftValue was saved
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantLocale TenantLocale @relation(fields: [tenantId, locale], references: [tenantId, locale], onDelete: Cascade)

  @@unique([tenantId, locale, resourceId])
  @@index([tenantId, locale])
  @@index([tenantId, resourceId])
}

// ============================================================================
// EMAIL TEMPLATES (Per-tenant email notification overrides)
// ============================================================================

/// Per-tenant email template overrides. Null content fields mean
/// "use platform default" from the email event registry.
/// One row per tenant per event type — unique constraint enforced.
model EmailTemplate {
  id          String         @id @default(cuid())
  tenantId    String
  eventType   EmailEventType

  /// Null = use platform default subject
  subject     String?
  /// Null = use platform default preview text
  previewText String?
  /// Null = use platform default HTML (from react-email components)
  html        String?        @db.Text

  /// Per-tenant toggle — only respected for events with canDisable: true
  enabled     Boolean        @default(true)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eventType])
  @@index([tenantId])
}

// ============================================================================
// EMAIL SEND LOG (Append-only audit trail for all outgoing emails)
// ============================================================================

/// One row per send attempt through sendEmailEvent().
/// Updated by Resend webhooks as delivery status progresses.
model EmailSendLog {
  id            String          @id @default(cuid())
  tenantId      String
  eventType     EmailEventType
  toEmail       String
  resendId      String?         // Resend's message ID, set after successful send
  status        EmailSendStatus @default(QUEUED)
  error         String?         // error message if status = FAILED
  attempts      Int             @default(0)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?
  failureReason String?
  variables     Json?           // template variables for retry replay
  orderId       String?         // link to order for dedup (abandoned checkout, payment failed)
  bookingId     String?         // link to booking for dedup (pre-arrival, post-stay)
  sentAt        DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([resendId])
  @@index([toEmail])
  @@index([tenantId, eventType])
  @@index([status, nextRetryAt])
  @@index([orderId, eventType])
  @@index([bookingId, eventType])
}

// ============================================================================
// EMAIL UNSUBSCRIBE (Per-tenant opt-out registry)
// ============================================================================

/// Legacy unsubscribe table for guests without GuestAccount.
/// New consent is stored on GuestAccount.emailMarketingState.
/// Keep for backwards compatibility with existing unsubscribe tokens.
///
/// Stores opt-out per email address per tenant. Once a record exists,
/// no further emails are sent to that address from that tenant.
model EmailUnsubscribe {
  id              String   @id @default(cuid())
  tenantId        String
  email           String
  unsubscribedAt  DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

// ============================================================================
// EMAIL DOMAINS (Per-tenant sender domain verification via Resend)
// ============================================================================

enum EmailDomainStatus {
  PENDING     // added, DNS not yet configured
  VERIFIED    // Resend confirmed DNS records are correct
  FAILED      // verification failed
}

/// Per-tenant sender domain. Once verified, emails are sent from
/// noreply@[domain] instead of onboarding@resend.dev.
model EmailDomain {
  id              String            @id @default(cuid())
  tenantId        String
  domain          String            // e.g. "grandhotel.se"
  resendDomainId  String?           // Resend's domain ID after creation
  status          EmailDomainStatus @default(PENDING)
  dnsRecords      Json?             // DNS records returned by Resend
  verifiedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, domain])
  @@index([tenantId])
}

// ============================================================================
// MAGIC LINK TOKENS (Guest portal email-based authentication)
// ============================================================================

/// Email-based magic link tokens for guest portal authentication.
/// Not booking-scoped — a guest authenticates with email, then sees
/// all bookings for that email address on the tenant.
/// Tokens are single-use, time-limited, and rate-limited per email.
model MagicLinkToken {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tenantId, email])
  @@index([expiresAt])
}

// ============================================================================
// EMAIL RATE LIMITING (Per-recipient per-event-type throttle)
// ============================================================================

/// Append-only send log for rate limiting.
/// We count rows in a rolling time window rather than maintaining counters.
/// Simple, debuggable, no update races.
/// Cleaned up daily by /api/integrations/cleanup.
model EmailRateLimit {
  id        String         @id @default(cuid())
  tenantId  String
  email     String
  eventType EmailEventType
  sentAt    DateTime       @default(now())

  @@index([tenantId, email, eventType, sentAt])
}

// ============================================================================
// GUEST ACCOUNTS (OTP-based guest authentication)
// ============================================================================

/// Per-tenant guest account. One account per email per tenant.
/// Created lazily during booking sync when a valid guest email exists.
/// Shopify-grade guest customer model.
/// One account per email per tenant. Created lazily on order payment,
/// booking sync, or OTP login. Owns marketing consent, tags, notes,
/// addresses, and a full event audit trail.
model GuestAccount {
  id          String   @id @default(cuid())
  tenantId    String
  email       String
  name        String?   // @deprecated — use firstName/lastName. Kept for backwards compat.
  phone       String?   // Populated from first order/booking
  firstName   String?
  lastName    String?
  address1    String?
  address2    String?
  city        String?
  postalCode  String?
  country     String?   @default("SE")

  // Identity
  locale           String?                // "sv" | "en" | "de" — language preference
  verifiedEmail    Boolean  @default(false)

  // State (Shopify CustomerState equivalent)
  state            GuestAccountState @default(ENABLED)

  // Internal
  note             String?           // internal staff note, never shown to guest

  // Marketing consent (replaces EmailUnsubscribe for new accounts)
  emailMarketingState     GuestMarketingState @default(NOT_SUBSCRIBED)
  emailConsentedAt        DateTime?
  emailConsentSource      String?   // "checkout" | "portal" | "import" | "manual"
  emailOptInLevel         GuestOptInLevel @default(SINGLE_OPT_IN)
  smsMarketingState       GuestMarketingState @default(NOT_SUBSCRIBED)
  smsConsentedAt          DateTime?

  // GDPR
  dataSaleOptOut          Boolean  @default(false)
  dataSaleOptOutAt        DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]
  orders   Order[]
  otpCodes GuestOtpCode[]
  tags             GuestTag[]
  notes            GuestNote[]
  events           GuestAccountEvent[]
  addresses        GuestAddress[]
  segmentMemberships   GuestSegmentMembership[]
  discountTargets      DiscountCustomer[]
  campaignRecipients   CampaignRecipient[]
  automationEnrollments AutomationEnrollment[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([tenantId, state])
  @@index([tenantId, emailMarketingState])
  @@index([tenantId, createdAt])
}

/// OTP codes for guest authentication.
/// Codes are stored hashed — never in cleartext.
/// Single-use: usedAt is set on verification.
model GuestOtpCode {
  id             String   @id @default(cuid())
  guestAccountId String
  codeHash       String
  expiresAt      DateTime
  usedAt         DateTime?
  failedAttempts Int      @default(0)
  createdAt      DateTime @default(now())

  guestAccount GuestAccount @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)

  @@index([guestAccountId])
}

/// Guest tags — tenant-scoped, lowercase, for segmentation and filtering.
/// Many-to-many via unique constraint per guest+tag.
model GuestTag {
  id             String       @id @default(cuid())
  tenantId       String
  guestAccountId String
  tag            String       // lowercase, e.g. "vip", "allergi", "företag"
  createdAt      DateTime     @default(now())
  createdBy      String?      // actorUserId who added it

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guestAccount GuestAccount @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)

  @@unique([tenantId, guestAccountId, tag])
  @@index([tenantId, tag])
  @@index([guestAccountId])
}

/// Internal staff notes on a guest. Never shown to the guest.
/// Append-oriented — edits tracked via updatedBy.
model GuestNote {
  id             String   @id @default(cuid())
  tenantId       String
  guestAccountId String
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?  // actorUserId
  updatedBy      String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guestAccount GuestAccount @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId, guestAccountId])
}

/// Append-only audit trail for guest account lifecycle events.
/// Never UPDATE, never DELETE — immutable log.
model GuestAccountEvent {
  id             String         @id @default(cuid())
  tenantId       String
  guestAccountId String
  type           GuestEventType
  message        String?
  metadata       Json?
  actorUserId    String?        // null = system
  ipAddress      String?
  userAgent      String?
  orderId        String?        // Links order-lifecycle events for idempotency
  createdAt      DateTime       @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guestAccount GuestAccount @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)

  @@unique([guestAccountId, orderId, type], name: "guest_event_order_idempotency")
  @@index([tenantId, guestAccountId])
  @@index([tenantId, type])
  @@index([guestAccountId, createdAt])
}

/// Guest addresses — one per entry, one marked as default.
/// Shopify model: customers can have multiple saved addresses.
model GuestAddress {
  id             String   @id @default(cuid())
  tenantId       String
  guestAccountId String
  isDefault      Boolean  @default(false)
  firstName      String?
  lastName       String?
  company        String?
  address1       String
  address2       String?
  city           String
  postalCode     String?
  province       String?
  country        String   @default("SE")
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guestAccount GuestAccount @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId, guestAccountId])
  @@index([guestAccountId, isDefault])
}

// ============================================================================
// PRODUCT CATALOG (Shopify-grade product infrastructure)
// ============================================================================

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum ProductType {
  STANDARD
  GIFT_CARD
}

enum InventoryChangeReason {
  PURCHASE
  MANUAL_ADJUSTMENT
  RETURN
  RESERVATION
  RESERVATION_RELEASED
  INITIAL
}

/// Core product model. Every sellable item — breakfast buffet, bike rental,
/// welcome package, room upgrade — is a Product.
///
/// Shopify parity:
///   - Title, description (rich text), status (active/draft)
///   - Media (images + video via ProductMedia join)
///   - Price (base price on product, overridable per variant)
///   - Inventory tracking (optional, per product or per variant)
///   - Variants (option-based: "Tid" → "07:00", "08:30")
///   - Collections (many-to-many via ProductCollectionItem)
///
/// Pricing strategy:
///   - Product has a base price (used when no variants exist)
///   - Each variant can override price independently
///   - Prices stored in smallest currency unit (ören/cents)
///
/// Inventory strategy:
///   - trackInventory: false → unlimited stock, no tracking
///   - trackInventory: true → inventoryQuantity is source of truth
///   - continueSellingWhenOutOfStock: allows overselling when true
///   - When variants exist, inventory is tracked PER VARIANT (not product)
model Product {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ── Core fields ────────────────────────────────────────────
  title       String
  description String   @db.Text   @default("")
  slug        String               // URL-safe, auto-generated from title

  status      ProductStatus @default(DRAFT)
  productType ProductType   @default(STANDARD)

  // ── Pricing ────────────────────────────────────────────────
  /// Base price in smallest currency unit (ören). Used when no variants exist.
  /// When variants exist, each variant has its own price.
  price       Int       @default(0)
  currency    String    @default("SEK")

  /// Compare-at price for showing discounts (crossed-out price). Null = no discount.
  compareAtPrice Int?

  // ── Inventory (product-level) ──────────────────────────────
  /// Whether to track inventory for this product.
  /// When variants exist, inventory is tracked per variant instead.
  trackInventory              Boolean @default(false)
  /// Available quantity. Only meaningful when trackInventory = true AND no variants.
  inventoryQuantity           Int     @default(0)
  /// Allow purchases even when inventory is 0.
  continueSellingWhenOutOfStock Boolean @default(false)

  // ── Tax ─────────────────────────────────────────────────────
  /// Whether to charge VAT/tax on this product.
  taxable     Boolean   @default(true)

  // ── Optimistic locking ─────────────────────────────────────
  /// Incremented on every update. Prevents concurrent overwrites.
  version     Int       @default(1)

  // ── Sort / display ─────────────────────────────────────────
  sortOrder   Int       @default(0)

  // ── Soft delete ────────────────────────────────────────────
  /// Null = active. Set = archived (hidden from storefront, data preserved).
  archivedAt  DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── Relations ──────────────────────────────────────────────
  media       ProductMedia[]
  options     ProductOption[]
  variants    ProductVariant[]
  collectionItems ProductCollectionItem[]
  tags            ProductTagItem[]
  inventoryChanges InventoryChange[]
  priceChanges PriceChange[]
  channelPublications ProductChannelPublication[]
  discountTargets     DiscountProduct[]

  // ── Template ────────────────────────────────────────────────
  /// Optional reference to a ProductTemplate for section layout.
  /// Null = use tenant's default template. Deleting a template nullifies this.
  templateId  String?
  template    ProductTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, productType])
  @@index([tenantId, sortOrder])
  @@index([tenantId, archivedAt])
}

/// Product media — images and videos attached to a product.
/// Ordered by sortOrder. First item (sortOrder=0) is the featured image.
///
/// References Cloudinary URLs directly (same pattern as MediaAsset).
/// Supports both images and video.
model ProductMedia {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// Cloudinary delivery URL
  url       String
  /// "image" or "video"
  type      String    @default("image")
  /// Alt text for accessibility
  alt       String    @default("")
  /// Display order (0 = featured image)
  sortOrder Int       @default(0)
  /// Original filename
  filename  String    @default("")
  /// Width in pixels (images only)
  width     Int?
  /// Height in pixels (images only)
  height    Int?

  createdAt DateTime  @default(now())

  @@index([productId])
  @@index([productId, sortOrder])
}

/// Product option — a named axis of variation (e.g. "Tid", "Storlek").
/// Each option has multiple values (e.g. "07:00", "08:30").
///
/// Shopify allows up to 3 options per product. We enforce the same limit
/// in application code (not DB constraint — easier to change later).
///
/// Options are ordered by sortOrder. Values are stored as a JSON array
/// to preserve ordering without a separate table.
model ProductOption {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// Display name (e.g. "Tid", "Storlek", "Färg")
  name      String
  /// Ordered list of option values (e.g. ["07:00", "08:30", "10:00"])
  values    Json      // String[]
  /// Display order among options
  sortOrder Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([productId, name])
  @@index([productId])
}

/// Product variant — a specific combination of option values.
/// Each variant can have its own price, inventory, and SKU.
///
/// Shopify model: if a product has options "Tid" with ["07:00","08:30"]
/// and "Storlek" with ["Liten","Stor"], there are 4 variants:
///   07:00/Liten, 07:00/Stor, 08:30/Liten, 08:30/Stor
///
/// option1/option2/option3 store the selected value for each option
/// (positional — matches ProductOption.sortOrder 0/1/2).
///
/// When variants exist, product-level price/inventory are ignored.
/// Each variant is the source of truth for its own price and stock.
model ProductVariant {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// Selected value for option at position 0 (e.g. "07:00")
  option1   String?
  /// Selected value for option at position 1 (e.g. "Liten")
  option2   String?
  /// Selected value for option at position 2
  option3   String?

  /// Variant-specific image URL (Cloudinary). Shown on product page for this variant.
  imageUrl  String?

  /// Variant-specific price in smallest currency unit. Overrides product.price.
  price     Int
  /// Compare-at price for showing discounts. Null = no discount.
  compareAtPrice Int?

  /// SKU — stock keeping unit (optional, tenant-defined)
  sku       String?

  /// Whether this variant tracks inventory.
  trackInventory              Boolean @default(false)
  /// Available quantity for this specific variant.
  inventoryQuantity           Int     @default(0)
  /// Allow purchases when this variant's stock is 0.
  continueSellingWhenOutOfStock Boolean @default(false)

  /// Optimistic locking — incremented on every mutation.
  version   Int       @default(1)

  /// Display order among variants
  sortOrder Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  inventoryChanges InventoryChange[]

  @@index([productId])
  @@index([productId, sortOrder])
  @@index([productId, sku])
}

// ============================================================================
// PRODUCT TEMPLATES (Shopify-style alternate templates)
// ============================================================================

/// Product template — metadata for alternate product detail page layouts.
/// Each tenant can have multiple templates (e.g. "Standard", "Highlight", "Minimal").
/// Exactly one template per tenant must have isDefault = true (enforced at app layer).
///
/// Shopify parity:
///   - Alternate templates: product.json, product.highlight.json
///   - We use page IDs: "shop-product", "shop-product.highlight"
///   - Sections live in TenantConfig.pages["shop-product.{suffix}"], NOT here
///   - Products reference a template; deleting a template nullifies the reference
model ProductTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Display name shown in admin (e.g. "Standard", "Highlight", "Minimal")
  name      String
  /// URL/lookup key (e.g. "default", "highlight", "minimal")
  suffix    String
  /// Exactly one per tenant must be true (enforced at application layer)
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]

  @@unique([tenantId, suffix])
  @@index([tenantId])
  @@index([tenantId, isDefault])
}

// ============================================================================
// PRODUCT COLLECTIONS (Shopify-grade collection infrastructure)
// ============================================================================

/// Product collection — a named group of products.
/// Products can belong to multiple collections (many-to-many).
///
/// Examples: "Mat & Dryck", "Aktiviteter", "Paket", "Alla produkter"
///
/// Shopify parity:
///   - Title, description, image
///   - Manual sorting via ProductCollectionItem.sortOrder
///   - Products can be in multiple collections simultaneously
model ProductCollection {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String   @db.Text   @default("")
  slug        String               // URL-safe
  imageUrl    String?              // Collection cover image

  /// ACTIVE = visible on storefront, DRAFT = hidden. Does NOT affect products in the collection.
  status      ProductStatus @default(DRAFT)

  sortOrder   Int       @default(0)

  /// Optimistic locking — incremented on every update
  version     Int       @default(1)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items       ProductCollectionItem[]
  discountTargets DiscountCollection[]
  accommodationCategoryAddons AccommodationCategoryAddon[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, sortOrder])
}

/// Join table: Product ↔ Collection (many-to-many with sort order).
/// A product can appear in multiple collections.
/// Each membership has its own sort position within that collection.
model ProductCollectionItem {
  id           String @id @default(cuid())
  collectionId String
  collection   ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// Position within this collection
  sortOrder    Int       @default(0)

  createdAt    DateTime  @default(now())

  @@unique([collectionId, productId])
  @@index([collectionId, sortOrder])
  @@index([productId])
}

// ============================================================================
// ACCOMMODATION (First-class accommodation model — replaces PMS_ACCOMMODATION on Product)
// ============================================================================

/// First-class accommodation model. Hotels, cabins, camping pitches, apartments.
/// Separated from Product to give accommodations their own structured fields
/// (capacity, facilities, bed configs, rate plans, restrictions, media).
///
/// PMS sync writes to this model. Tenant can override name/description.
/// resolveAccommodation() reads nameOverride ?? pmsName ?? name.
model Accommodation {
  id       String @id @default(cuid())
  tenantId String

  // Identity
  name            String
  slug            String
  shortName       String?
  externalCode    String?   // BookVisit "Kod" / PMS short code
  externalId      String?   // PMS room type ID (was pmsSourceId)
  pmsProvider     String?   // "mews" | "bookvisit" | "manual" | "fake"
  pmsSyncedAt     DateTime?
  pmsData         Json?     // Raw PMS snapshot — kept for debugging only, never read in app code

  // Type & status
  accommodationType AccommodationType
  status            AccommodationStatus @default(ACTIVE)

  // Content — override pattern: resolveAccommodation() always reads nameOverride ?? pmsName ?? name
  nameOverride        String?
  descriptionOverride String? @db.Text
  description         String  @db.Text @default("")

  // Capacity
  maxGuests     Int
  minGuests     Int  @default(1)
  defaultGuests Int?
  maxAdults     Int?
  minAdults     Int?
  maxChildren   Int?
  minChildren   Int?
  extraBeds     Int  @default(0)

  // Physical
  roomSizeSqm  Float?
  bedrooms     Int?
  bathrooms    Int?
  floorNumber  Int?

  // Pricing (local snapshot — fallback display only, never used for checkout validation)
  basePricePerNight Int     @default(0) // ören
  currency          String  @default("SEK")

  // Tax
  taxRate Int @default(0) // basis points e.g. 1200 = 12%

  // Availability baseline (total units available when fully open)
  totalUnits     Int @default(1)
  baseAvailability Int @default(1) // BookVisit: "Tillgänglighet"

  // PMS group / category mapping
  roomTypeGroupId String? // BookVisit: "Rumstypsgrupp"

  // Sorting
  sortOrder Int @default(0)

  // Timestamps
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  units        AccommodationUnit[]
  facilities   AccommodationFacility[]
  bedConfigs   BedConfiguration[]
  ratePlans    RatePlan[]
  restrictions AccommodationRestriction[]
  media        AccommodationMedia[]
  highlights       AccommodationHighlight[]
  checkoutSessions CheckoutSession[]
  bookings         Booking[]
  categoryItems AccommodationCategoryItem[]
  spotMarkers   SpotMarker[]

  @@unique([tenantId, slug])
  @@unique([tenantId, externalId, pmsProvider])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, accommodationType])
  @@index([tenantId, sortOrder])
  @@index([tenantId, archivedAt])
  @@index([tenantId, pmsProvider, externalId])
}

/// Highlight / selling point on an accommodation.
/// e.g. icon "star" + text "Fem stjärnigt hotell"
/// Tenant-managed, ordered by sortOrder.
model AccommodationHighlight {
  id              String @id @default(cuid())
  accommodationId String

  icon        String  // Material Symbols Rounded icon name, e.g. "star", "wifi"
  text        String  // Heading, e.g. "Fem stjärnigt hotell"
  description String  @default("") // Optional description below the heading
  sortOrder   Int     @default(0)

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@index([accommodationId])
  @@index([accommodationId, sortOrder])
}

/// Physical room/unit within an accommodation category.
/// e.g. "Room 101", "Stuga 4", "Plats A12"
model AccommodationUnit {
  id              String @id @default(cuid())
  tenantId        String
  accommodationId String

  // Identity
  name       String   // e.g. "101", "Stuga 4", "Plats A12"
  externalId String?  // PMS physical room ID (Mews: Resource.Id)
  floor      Int?
  notes      String?

  status AccommodationUnitStatus @default(AVAILABLE)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, accommodationId, name])
  @@index([tenantId])
  @@index([accommodationId])
  @@index([tenantId, status])
}

/// Normalized facility on an accommodation — enum-based, not JSON.
/// PMS sync creates entries with source=PMS. Tenant can add MANUAL ones.
/// overrideHidden lets tenant suppress a PMS-synced facility from display.
model AccommodationFacility {
  id              String @id @default(cuid())
  accommodationId String

  facilityType    FacilityType
  source          FacilitySource @default(MANUAL)
  overrideHidden  Boolean        @default(false) // tenant can hide a PMS-synced facility

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@unique([accommodationId, facilityType])
  @@index([accommodationId])
}

/// Bed configuration for an accommodation — normalized, not JSON.
model BedConfiguration {
  id              String @id @default(cuid())
  accommodationId String

  bedType  BedType
  quantity Int     @default(1)

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@unique([accommodationId, bedType])
  @@index([accommodationId])
}

/// Rate plan for an accommodation — pricing option (flexible, non-refundable, etc.).
/// PMS sync upserts these. Display-only pricing snapshot.
model RatePlan {
  id              String @id @default(cuid())
  tenantId        String
  accommodationId String

  externalId   String? // PMS rate plan ID
  name         String
  description  String? @db.Text

  cancellationPolicy     RatePlanCancellationPolicy @default(FLEXIBLE)
  cancellationDescription String?                   @db.Text

  // Pricing snapshot — updated on sync, used for display only
  pricePerNight Int    // ören
  currency      String @default("SEK")

  status    RatePlanStatus @default(ACTIVE)
  validFrom DateTime?
  validTo   DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@unique([accommodationId, externalId])
  @@index([tenantId])
  @@index([accommodationId])
  @@index([accommodationId, status])
}

/// Per-date restriction on an accommodation — min stay, CTA/CTD, etc.
model AccommodationRestriction {
  id              String @id @default(cuid())
  tenantId        String
  accommodationId String

  restrictionType RestrictionType
  date            DateTime        // The specific date this restriction applies to
  value           Int?            // For MIN_STAY / MAX_STAY: number of nights. Null for boolean restrictions.
  source          FacilitySource  @default(MANUAL)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@unique([accommodationId, restrictionType, date])
  @@index([tenantId])
  @@index([accommodationId])
  @@index([accommodationId, date])
}

/// Media (images) attached to an accommodation. Ordered by sortOrder.
model AccommodationMedia {
  id              String @id @default(cuid())
  accommodationId String

  url       String
  altText   String?
  sortOrder Int     @default(0)
  source    FacilitySource @default(MANUAL)

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@index([accommodationId])
  @@index([accommodationId, sortOrder])
}

// ============================================================================
// ACCOMMODATION CATEGORIES (Tenant-defined grouping of accommodations)
// ============================================================================

/// Tenant-defined category for grouping accommodations.
/// Parallel to ProductCollection — manual grouping with optional PMS-seed.
/// Examples: "Hotell", "Stugor", "Premium camping", "Sommarpaket"
model AccommodationCategory {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String   @db.Text @default("")
  slug        String
  imageUrl    String?
  status      AccommodationStatus @default(ACTIVE)
  /// Whether this category appears in the guest search form filter.
  /// When false, accommodations in this category are hidden from search results.
  visibleInSearch Boolean @default(true)
  sortOrder   Int      @default(0)
  /// PMS type string that seeded this category (e.g. "HOTEL").
  /// Null for manually created categories. Never overwritten by sync.
  pmsRef      String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  AccommodationCategoryItem[]
  addonCollections AccommodationCategoryAddon[]
  spotMaps SpotMap[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, visibleInSearch])
  @@index([tenantId, sortOrder])
}

/// Join table: Accommodation ↔ AccommodationCategory (many-to-many with sort order).
model AccommodationCategoryItem {
  id              String   @id @default(cuid())
  categoryId      String
  accommodationId String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  category      AccommodationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  accommodation Accommodation         @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@unique([categoryId, accommodationId])
  @@index([categoryId, sortOrder])
  @@index([accommodationId])
}

/// Links an AccommodationCategory to a ProductCollection whose products
/// are offered as addons when booking accommodations in that category.
model AccommodationCategoryAddon {
  id           String   @id @default(cuid())
  categoryId   String
  collectionId String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  category   AccommodationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  collection ProductCollection     @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([categoryId, collectionId])
  @@index([categoryId, sortOrder])
  @@index([collectionId])
}

// ============================================================================
// CHECKOUT SESSION (Source of truth for the entire purchase flow)
// ============================================================================

/// Tracks a guest's journey from "Boka" click through addon selection
/// to payment. URL params are NOT the source of truth — this is.
/// Token is the only external identifier. Internal id never exposed.
enum CheckoutSessionStatus {
  PENDING           // Created, awaiting addon selection
  ADDON_SELECTION   // Guest is selecting addons
  CHECKOUT          // Ready for payment (or skipped addons)
  COMPLETED         // Payment successful, order created
  EXPIRED           // Timed out (30min TTL)
  ABANDONED         // Guest navigated away
}

enum CheckoutSessionType {
  ACCOMMODATION
  CART
}

model CheckoutSession {
  id       String @id @default(cuid())
  token    String @unique                     // 32 random bytes, base64url — used in all URLs
  tenantId String

  status      CheckoutSessionStatus @default(PENDING)
  sessionType CheckoutSessionType  @default(ACCOMMODATION)

  // ── Accommodation fields (null for CART sessions) ──────────
  accommodationId   String?
  accommodation     Accommodation? @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  ratePlanId        String?        // PMS external ID — not a FK, rate plans are not persisted

  // Stay details (null for CART sessions)
  checkIn   DateTime?
  checkOut  DateTime?
  adults    Int?

  // Frozen snapshot — prices from PMS at session creation time, all in öre (Int)
  accommodationName               String?
  accommodationSlug               String?
  ratePlanName                     String?
  ratePlanCancellationPolicy       String?  // "FLEXIBLE" | "MODERATE" | "NON_REFUNDABLE"
  pricePerNight                    Int?     // öre
  totalNights                      Int?
  accommodationTotal               Int?     // pricePerNight × totalNights, öre
  currency                         String   @default("SEK")

  // ── Cart fields (null for ACCOMMODATION sessions) ──────────
  cartItems  Json?    // CartItem[] snapshot — frozen at session creation, öre prices
  cartTotal  Int?     // sum of (unitAmount × quantity), öre

  // Addons — frozen at selection time
  selectedAddons Json @default("[]")
  // Shape: Array<{ productId, variantId, title, quantity, unitAmount, totalAmount, pricingMode }>

  // Dedup: prevents rapid double-clicks from creating duplicate sessions
  dedupKey   String?  @unique

  // Lifecycle
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([expiresAt])
}

// ============================================================================
// PRODUCT TAGS (Global tag registry + product-tag association)
// ============================================================================

/// Global tag registry — shared across all products for a tenant.
/// Normalized: each unique tag string exists once per tenant.
/// Enables tag-based search, filtering, and autocomplete.
model ProductTag {
  id       String @id @default(cuid())
  tenantId String

  /// Normalized tag name (lowercase, trimmed)
  name     String

  createdAt DateTime @default(now())

  items    ProductTagItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Join table: Product ↔ Tag (many-to-many).
model ProductTagItem {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     String
  tag       ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, tagId])
  @@index([productId])
  @@index([tagId])
}

// ============================================================================
// INVENTORY LEDGER (Append-only audit trail for stock changes)
// ============================================================================

/// Every inventory change — purchase, manual adjustment, return, reservation —
/// is recorded as an immutable ledger entry. Never updated, never deleted.
///
/// The current quantity is the SUM of all changes for that product/variant.
/// Product.inventoryQuantity / Variant.inventoryQuantity are denormalized
/// caches updated atomically alongside each ledger entry.
///
/// This is the Shopify model: you can always reconstruct inventory history
/// and answer "why did the stock change?"
model InventoryChange {
  id        String @id @default(cuid())
  tenantId  String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// Null when the change applies to the product level (no variants).
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  /// Signed quantity delta. Negative = stock decreased (purchase, adjustment down).
  /// Positive = stock increased (return, adjustment up, initial stock).
  quantityDelta Int

  /// Resulting quantity AFTER this change was applied.
  /// Denormalized for fast reads — avoids summing the entire ledger.
  quantityAfter Int

  /// Why this change happened.
  reason    InventoryChangeReason

  /// Human-readable note (e.g. "Manuell justering", "Order #1234")
  note      String?

  /// Who triggered this change. Null for system/automated changes (purchases).
  actorUserId String?

  /// Reference to the order/reservation that caused this change.
  referenceId String?

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([variantId])
  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@index([reason])
}

// ============================================================================
// PRICE HISTORY (Audit trail for price changes)
// ============================================================================

/// Every price change on a product or variant is recorded.
/// Append-only — never updated, never deleted.
/// Used for analytics, audit, and "was this price correct at order time?"
model PriceChange {
  id        String @id @default(cuid())
  tenantId  String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// Null when the change applies to the product-level price.
  variantId String?

  /// Price BEFORE this change (smallest currency unit).
  previousPrice Int
  /// Price AFTER this change (smallest currency unit).
  newPrice      Int
  /// Currency code at time of change.
  currency      String

  /// Who changed the price. Null for system/automated changes.
  actorUserId   String?

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
}

// ============================================================================
// INVENTORY RESERVATIONS (Soft locks for cart/checkout)
// ============================================================================

/// Temporary stock reservation created when an item is added to cart.
/// Prevents overselling by holding stock for a limited time.
/// Released on purchase (converted to InventoryChange) or expiry.
///
/// TTL: 15 minutes (configurable). Expired reservations are cleaned up
/// by a periodic job and stock is released.
model InventoryReservation {
  id        String @id @default(cuid())
  tenantId  String

  productId String
  variantId String?

  /// Number of units reserved.
  quantity  Int

  /// When this reservation expires and stock is released.
  expiresAt DateTime

  /// Session or cart identifier that owns this reservation.
  sessionId String

  /// Whether this reservation has been consumed (converted to a purchase).
  consumed  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, variantId])
  @@index([expiresAt])
  @@index([sessionId])
}

// ============================================================================
// ORDERS (Commerce — Shopify-grade order management)
// ============================================================================

model Order {
  id                      String      @id @default(cuid())
  tenantId                String
  tenant                  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Sequential per tenant — human-friendly order number (e.g. #1001)
  orderNumber             Int

  status                  OrderStatus    @default(PENDING)
  financialStatus         OrderFinancialStatus  @default(PENDING)
  fulfillmentStatus       OrderFulfillmentStatus @default(UNFULFILLED)
  orderType               OrderType      @default(ACCOMMODATION)
  paymentMethod           PaymentMethod  @default(STRIPE_CHECKOUT)

  // Guest info — denormalized for fast display (nullable for Elements flow where collected later)
  guestEmail              String         @default("")
  guestName               String         @default("")
  guestPhone              String?
  billingAddress          Json?    // { address1, address2?, city, postalCode, country }

  // Guest account link — auto-created on payment
  guestAccountId          String?
  guestAccount            GuestAccount?  @relation(fields: [guestAccountId], references: [id], onDelete: SetNull)

  // Money — always integer (ören/cents), never float
  subtotalAmount          Int           // before tax
  taxAmount               Int           @default(0)
  taxRate                 Int           @default(0)  // basis points, e.g. 2500 = 25%
  totalAmount             Int           // what guest paid
  currency                String        @default("SEK")

  // Discount — snapshot at checkout time
  discountAmount          Int           @default(0) // total discount in ören
  discountCode            String?       // code used (null for automatic discounts)

  // @deprecated — use PaymentSession.externalSessionId for lookups.
  // Kept for backwards compatibility with existing orders.
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId   String?       @unique

  /// Platform fee charged on this order, snapshot at payment time
  platformFeeBps          Int?

  /// Public token for unauthenticated order status lookup.
  /// Safe to share in emails. Reveals only status and summary.
  statusToken             String?       @unique @default(cuid())

  /// Comma-separated tags for categorization (Shopify pattern)
  tags                    String            @default("")

  /// Customer-facing note — set by guest at checkout (special requests, vehicle length, etc.)
  customerNote            String?

  /// Flexible metadata — accommodation dates, PMS refs, etc.
  metadata                Json?

  // Sales channel attribution — which channel originated this order
  sourceChannel           String?   // "direct" | "booking_com" | "expedia" | app-handle
  sourceExternalId        String?   // booking ID from OTA (e.g. "BK-12345678")
  sourceUrl               String?   // link to the order on the OTA platform

  // Timestamps
  paidAt                  DateTime?
  fulfilledAt             DateTime?
  cancelledAt             DateTime?
  refundedAt              DateTime?
  archivedAt              DateTime?     // Null = active, set = archived (hidden from default list)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  // Relations
  lineItems               OrderLineItem[]
  events                  OrderEvent[]
  giftCard                GiftCard?
  paymentSession          PaymentSession?
  discountAllocations     DiscountAllocation[]
  discountUsage           DiscountUsage?
  bookings                Booking[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([guestEmail])
  @@index([guestAccountId])
  @@index([status, createdAt])
  @@index([tenantId, sourceChannel])
  @@index([tenantId, financialStatus])
  @@index([tenantId, financialStatus, createdAt])
  @@index([tenantId, fulfillmentStatus])
}

/// Tracks which products are published to which sales channels.
/// A product can be published to multiple channels simultaneously.
/// Unpublishing sets unpublishedAt — row is preserved for history.
model ProductChannelPublication {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  channelHandle String
  publishedAt   DateTime  @default(now())
  unpublishedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, productId, channelHandle])
  @@index([tenantId, channelHandle])
  @@index([tenantId, productId])
}

model OrderLineItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId     String
  variantId     String?

  // Snapshot — frozen at purchase time — NEVER join back to Product
  title         String   // product title at purchase time
  variantTitle  String?  // variant label at purchase time
  sku           String?
  imageUrl      String?

  quantity      Int
  unitAmount    Int      // price per unit in ören/cents
  totalAmount   Int      // quantity * unitAmount
  currency      String   @default("SEK")

  // Discount — allocated amount for this line
  discountAmount      Int                  @default(0)
  discountAllocations DiscountAllocation[]

  @@index([orderId])
  @@index([productId])
}

model OrderEvent {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenantId    String

  type        OrderEventType
  message     String
  metadata    Json            @default("{}")
  actorUserId String?         // Clerk userId or null for system events
  actorName   String?         // Display name at time of event (denormalized)
  createdAt   DateTime        @default(now())

  @@index([orderId, createdAt])
  @@index([tenantId, orderId])
}

// ============================================================================
// DISCOUNTS
// ============================================================================

/// Core discount definition. Shopify-grade: supports both automatic and
/// code-based discounts, percentage or fixed amount, order or line-item level.
/// Monetary values follow platform convention: ören (smallest currency unit).
model Discount {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String            // internal admin label
  description String?           // shown to guest for AUTOMATIC discounts

  method      DiscountMethod
  valueType   DiscountValueType
  value       Int               // bps if PERCENTAGE, ören if FIXED_AMOUNT
  targetType  DiscountTargetType

  // Targeting scope — explicit flags, not inferred by absence of conditions
  appliesToAllProducts   Boolean @default(true)
  appliesToAllCustomers  Boolean @default(true)

  // Minimum purchase requirement — typed fields, not EAV condition rows
  minimumAmount          Int?    // in ören — null = no minimum
  minimumQuantity        Int?    // item count — null = no minimum

  status      DiscountStatus    @default(ACTIVE)

  startsAt    DateTime          @default(now())
  endsAt      DateTime?

  usageLimit  Int?              // null = unlimited
  usageCount  Int               @default(0) // denormalized — source of truth is COUNT(DiscountUsage)

  combinesWithProductDiscounts  Boolean @default(false)
  combinesWithOrderDiscounts    Boolean @default(false)
  combinesWithShippingDiscounts Boolean @default(false)

  createdByUserId String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  codes       DiscountCode[]
  conditions  DiscountCondition[]
  allocations DiscountAllocation[]
  usages      DiscountUsage[]
  events      DiscountEvent[]
  targetedProducts    DiscountProduct[]
  targetedCollections DiscountCollection[]
  targetedSegments    DiscountSegment[]
  targetedCustomers   DiscountCustomer[]

  @@index([tenantId, status])
  @@index([tenantId, method])
  @@index([tenantId, startsAt, endsAt])
}

/// Discount codes — one discount can have multiple codes (e.g. "SUMMER2026", "VIP10").
/// Codes are always stored uppercase and trimmed. Unique per tenant.
model DiscountCode {
  id          String    @id @default(cuid())
  discountId  String
  discount    Discount  @relation(fields: [discountId], references: [id], onDelete: Cascade)
  tenantId    String

  code        String    // always stored UPPERCASE trimmed
  usageLimit  Int?      // overrides Discount.usageLimit for this code
  usageCount  Int       @default(0)
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())

  usages      DiscountUsage[]

  @@unique([tenantId, code])
  @@index([discountId])
  @@index([tenantId, isActive])
}

/// Conditions that must ALL be met for the discount to apply.
/// AND logic — every condition on the discount must pass.
model DiscountCondition {
  id          String                @id @default(cuid())
  discountId  String
  discount    Discount              @relation(fields: [discountId], references: [id], onDelete: Cascade)

  type        DiscountConditionType

  intValue    Int?     // MIN_NIGHTS, DAYS_IN_ADVANCE, MIN_ORDER_AMOUNT, MIN_ITEMS
  stringValue String?  // CUSTOMER_SEGMENT segmentId
  jsonValue   Json?    // SPECIFIC_PRODUCTS (string[]), ARRIVAL_WINDOW ({ startsAt, endsAt })

  @@index([discountId])
  @@index([discountId, type])
}

/// Normalized product targeting — replaces SPECIFIC_PRODUCTS jsonValue.
/// FK to Product ensures referential integrity + cascade on product deletion.
model DiscountProduct {
  id          String   @id @default(cuid())
  discountId  String
  discount    Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId    String

  @@unique([discountId, productId])
  @@index([discountId])
  @@index([tenantId, productId])
}

/// Normalized collection targeting.
/// FK to ProductCollection ensures referential integrity.
model DiscountCollection {
  id           String            @id @default(cuid())
  discountId   String
  discount     Discount          @relation(fields: [discountId], references: [id], onDelete: Cascade)
  collectionId String
  collection   ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  tenantId     String

  @@unique([discountId, collectionId])
  @@index([discountId])
  @@index([tenantId, collectionId])
}

/// Normalized customer segment targeting.
/// FK to GuestSegment ensures referential integrity.
model DiscountSegment {
  id         String       @id @default(cuid())
  discountId String
  discount   Discount     @relation(fields: [discountId], references: [id], onDelete: Cascade)
  segmentId  String
  segment    GuestSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  tenantId   String

  @@unique([discountId, segmentId])
  @@index([discountId])
  @@index([tenantId, segmentId])
}

/// Normalized specific customer targeting.
/// FK to GuestAccount ensures referential integrity.
model DiscountCustomer {
  id             String       @id @default(cuid())
  discountId     String
  discount       Discount     @relation(fields: [discountId], references: [id], onDelete: Cascade)
  guestAccountId String
  guestAccount   GuestAccount @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)
  tenantId       String

  @@unique([discountId, guestAccountId])
  @@index([discountId])
  @@index([tenantId, guestAccountId])
}

/// Records how a discount was distributed across an order.
/// Order-level discounts: orderLineItemId is null, amount is total discount.
/// Line-item discounts: one allocation per affected line item.
model DiscountAllocation {
  id              String         @id @default(cuid())
  orderId         String
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLineItemId String?        // null = order-level discount
  orderLineItem   OrderLineItem? @relation(fields: [orderLineItemId], references: [id], onDelete: SetNull)
  discountId      String
  discount        Discount       @relation(fields: [discountId], references: [id])
  tenantId        String

  amount          Int            // allocated discount amount in ören

  createdAt       DateTime       @default(now())

  @@index([orderId])
  @@index([discountId])
  @@index([tenantId])
}

/// Tracks each time a discount was used on an order.
/// One order can only redeem one discount (unique orderId).
/// Source of truth for usage counting — Discount.usageCount is denormalized.
model DiscountUsage {
  id             String        @id @default(cuid())
  discountId     String
  discount       Discount      @relation(fields: [discountId], references: [id], onDelete: Restrict)
  discountCodeId String?
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  tenantId       String

  orderId        String        @unique // one order can only redeem one discount
  order          Order         @relation(fields: [orderId], references: [id])
  guestAccountId String?
  guestEmail     String

  discountAmount Int           // actual amount discounted in ören
  voidedAt       DateTime?     // set when usage is cancelled/refunded — idempotency guard
  createdAt      DateTime      @default(now())

  @@index([discountId, createdAt])
  @@index([tenantId, guestEmail])
  @@index([tenantId, discountId])
}

/// Append-only audit log for discount lifecycle events.
model DiscountEvent {
  id          String             @id @default(cuid())
  discountId  String
  discount    Discount           @relation(fields: [discountId], references: [id], onDelete: Cascade)
  tenantId    String

  type        DiscountEventType
  message     String
  metadata    Json               @default("{}")
  actorUserId String?
  actorName   String?            // denormalized display name — set at write time

  createdAt   DateTime           @default(now())

  @@index([discountId, createdAt])
  @@index([tenantId])
}

/// Stripe webhook event deduplication — prevents double-processing.
/// Uses unique constraint on stripeEventId as atomic idempotency gate.
model StripeWebhookEvent {
  stripeEventId  String    @id   // evt_xxx — Stripe's unique event ID
  receivedAt     DateTime  @default(now())
  processedAt    DateTime?  // null = received but not yet successfully processed
  tenantId       String
  eventType      String

  @@index([tenantId])
}

/// Atomic counter for sequential order numbers per tenant.
/// Uses UPDATE ... RETURNING pattern for race-safe increment.
model OrderNumberSequence {
  tenantId    String   @id
  lastNumber  Int      @default(1000)
  updatedAt   DateTime @updatedAt
}

// ============================================================================
// GIFT CARDS
// ============================================================================

/// Per-tenant gift card configuration. One per tenant.
/// Controls whether gift cards are enabled and amount limits.
model GiftCardProduct {
  id         String   @id @default(cuid())
  tenantId   String
  title       String   @default("Presentkort")
  description String   @default("")
  slug        String   @default("")
  status      String   @default("DRAFT")  // ACTIVE or DRAFT
  enabled    Boolean  @default(false)
  minAmount  Int      @default(50000)    // 500 kr in ören
  maxAmount  Int      @default(1000000)  // 10 000 kr in ören
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  designs  GiftCardDesign[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

/// Visual design template for gift cards. Tenant picks from these.
model GiftCardDesign {
  id         String   @id @default(cuid())
  tenantId   String
  productId  String
  name       String   // display name in admin, max 80 chars
  imageUrl   String   // Cloudinary URL (background image when bgMode=image)
  config     Json?    // { logoUrl, bgMode, bgColor, bgGradientColor2, bgGradientDir }
  renderedImageUrl String?  // Pre-rendered PNG on Cloudinary (for email)
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product    GiftCardProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  giftCards  GiftCard[]

  @@index([tenantId])   // admin list: all designs for a tenant
  @@index([productId])  // product detail: designs for this gift card product
}

/// The actual gift card. Created when Order transitions PENDING → PAID.
/// Never created before payment is confirmed.
model GiftCard {
  id              String         @id @default(cuid())
  tenantId        String
  orderId         String         @unique  // one gift card per order
  code            String         // format: XXXX-XXXX-XXXX-XXXX
  designId        String?        // nullable — design can be deleted
  initialAmount   Int            // amount at issuance, in ören, immutable
  balance         Int            // current balance, in ören
  status          GiftCardStatus @default(PENDING)
  recipientEmail  String
  recipientName   String
  senderName      String
  message         String?        // optional personal message, max 500 chars
  scheduledAt     DateTime       // when email should be sent (now() for immediate)
  sentAt          DateTime?      // set when email actually sent
  expiresAt       DateTime?      // nullable, set per tenant policy (phase 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  design      GiftCardDesign?   @relation(fields: [designId], references: [id], onDelete: SetNull)
  redemptions GiftCardRedemption[]

  @@unique([tenantId, code])                    // code lookup for redemption
  @@index([tenantId])                           // admin list: all gift cards for tenant
  @@index([orderId])                            // order detail: gift card for this order
  @@index([tenantId, status, scheduledAt])      // cron: unsent cards ready for delivery
}

/// Append-only ledger of gift card redemptions (phase 2).
/// Created now to avoid future migration that alters GiftCard.
model GiftCardRedemption {
  id          String   @id @default(cuid())
  tenantId    String
  giftCardId  String
  orderId     String?  // FK to Order when redeemed at checkout
  amount      Int      // redeemed amount in ören
  createdAt   DateTime @default(now())
  // No updatedAt — append-only, never mutated

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])  // gift card detail: all redemptions
  @@index([tenantId])    // admin: all redemptions for tenant
}

// ============================================================================
// PAYMENT PROVIDER ABSTRACTION
// ============================================================================

/// Tracks the lifecycle of a single payment attempt for an Order.
/// One Order has at most one active PaymentSession.
/// The provider adapter creates and updates this record.
model PaymentSession {
  id                String               @id @default(cuid())
  orderId           String               @unique
  tenantId          String
  providerKey       String               // "bedfront_payments" | "swedbank_pay" etc.
  status            PaymentSessionStatus  @default(INITIATED)
  externalSessionId String?              // provider's own ID (e.g. Stripe PI id)
  externalRefundId  String?
  amount            Int                  // smallest currency unit (ören)
  currency          String
  initiatedAt       DateTime             @default(now())
  resolvedAt        DateTime?
  rawInitResponse   Json?                // full provider response for audit

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([providerKey, status])
  @@index([tenantId, status])
}

/// Which payment provider a tenant uses. One active provider per tenant.
/// Defaults to "bedfront_payments" (Stripe) if not configured.
model TenantPaymentConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  providerKey     String   @default("bedfront_payments")
  isActive        Boolean  @default(true)
  configuredAt    DateTime @default(now())
  configuredBy    String?  // Clerk userId

  /// AES-256-GCM encrypted credentials. Use credentials.ts to read/write.
  credentials     String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ============================================================================
// APP STORE (Shopify-style installable apps)
// ============================================================================

/// Status of an installed app for a tenant.
enum AppStatus {
  PENDING_SETUP   // installed but setup wizard not complete
  ACTIVE          // fully configured and running
  ERROR           // configuration error, needs attention
  PAUSED          // manually paused by tenant
  UNINSTALLED     // soft delete — kept for billing history
}

/// Lifecycle event types for app audit trail.
enum AppEventType {
  INSTALLED
  SETUP_STARTED
  SETUP_COMPLETED
  ACTIVATED
  PAUSED
  ERROR_OCCURRED
  ERROR_RESOLVED
  UNINSTALLED
  SETTINGS_UPDATED
  TIER_CHANGED
}

/// Per-tenant app installation. App definitions live in code (registry.ts),
/// this table stores only installation state and tenant-specific settings.
/// UNINSTALLED rows are kept for billing history — never hard-deleted.
model TenantApp {
  id            String      @id @default(cuid())
  tenantId      String
  appId         String      // references AppDefinition.id in registry
  status        AppStatus
  installedAt   DateTime    @default(now())
  activatedAt   DateTime?
  errorMessage  String?
  pricingTier   String?     // "free" | "grow" | "pro"
  settings      Json        @default("{}")  // app-specific config

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events        TenantAppEvent[]
  wizard        TenantAppWizard?
  health        TenantAppHealth?
  healthHistory TenantAppHealthHistory[]
  webhookDeliveries AppWebhookDelivery[]
  emailSyncs    EmailMarketingSync[]
  attributions  EmailAttribution[]
  spotMaps      SpotMap[]

  @@unique([tenantId, appId])
  @@index([tenantId, status])
}

/// Append-only audit trail for app lifecycle events.
/// Never UPDATE, never DELETE — immutable log.
model TenantAppEvent {
  id        String       @id @default(cuid())
  appId     String
  tenantId  String
  type      AppEventType
  message   String?
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())

  tenantApp TenantApp    @relation(fields: [tenantId, appId], references: [tenantId, appId], onDelete: Cascade)

  @@index([tenantId, appId])
  @@index([tenantId, createdAt])
}

/// Wizard state for app install flow. Tracks progress through
/// manifest-driven setup steps. One wizard per app per tenant.
/// Survives browser close — user can resume where they left off.
model TenantAppWizard {
  id              String      @id @default(cuid())
  tenantId        String
  appId           String
  currentStepId   String
  completedSteps  Json        @default("[]")
  stepData        Json        @default("{}")
  termsAccepted   Boolean     @default(false)
  termsAcceptedAt DateTime?
  planSelected    String?
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  abandonedAt     DateTime?

  tenantApp       TenantApp   @relation(fields: [tenantId, appId], references: [tenantId, appId], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@index([tenantId])
}

// ============================================================================
// APP HEALTH MONITORING
// ============================================================================

/// Current health state for an installed app. One per tenant per app.
/// Updated by checkAppHealth() — the ONLY function that writes here.
/// consecutiveFailures tracks unhealthy streak. At 3 → TenantApp.status = ERROR.
model TenantAppHealth {
  id                   String    @id @default(cuid())
  tenantId             String
  appId                String
  status               String    @default("UNCHECKED")
  latencyMs            Int?
  message              String?
  detail               String?
  consecutiveFailures  Int       @default(0)
  lastCheckedAt        DateTime?
  nextCheckAt          DateTime?

  tenantApp            TenantApp @relation(fields: [tenantId, appId], references: [tenantId, appId], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@index([tenantId])
  @@index([nextCheckAt])
}

/// Append-only health check history. One row per check execution.
/// Never UPDATE, never DELETE. Used for uptime chart (30-day view).
model TenantAppHealthHistory {
  id         String   @id @default(cuid())
  tenantId   String
  appId      String
  status     String
  latencyMs  Int?
  message    String?
  checkedAt  DateTime @default(now())

  tenantApp  TenantApp @relation(fields: [tenantId, appId], references: [tenantId, appId], onDelete: Cascade)

  @@index([tenantId, appId, checkedAt])
  @@index([checkedAt])
}

// ============================================================================
// APP WEBHOOKS (Platform event distribution to installed apps)
// ============================================================================

/// Append-only log of every platform event emitted.
/// Never UPDATE, never DELETE. Source of truth for "what happened".
model PlatformEventLog {
  id          String   @id @default(cuid())
  tenantId    String
  eventType   String   // "order.paid", "booking.confirmed", etc.
  payload     Json     // event-specific data
  emittedAt   DateTime @default(now())

  deliveries  AppWebhookDelivery[]

  @@index([tenantId, emittedAt])
  @@index([tenantId, eventType])
}

/// Tracks delivery of a platform event to a specific app's handler route.
/// One row per event per subscribed app. Retry logic uses exponential backoff.
/// Status transitions: PENDING→DELIVERED, PENDING→FAILED, FAILED→DELIVERED,
///   FAILED→FAILED (increment attempts), FAILED→EXHAUSTED. No other transitions.
model AppWebhookDelivery {
  id              String    @id @default(cuid())
  tenantId        String
  appId           String
  eventId         String
  eventType       String
  status          String    @default("PENDING") // PENDING | DELIVERED | FAILED | EXHAUSTED
  attempts        Int       @default(0)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  responseStatus  Int?      // HTTP status from handler
  responseTimeMs  Int?      // handler latency
  errorMessage    String?
  exhaustedAt     DateTime?
  createdAt       DateTime  @default(now())

  event           PlatformEventLog @relation(fields: [eventId], references: [id])
  tenantApp       TenantApp        @relation(fields: [tenantId, appId], references: [tenantId, appId], onDelete: Cascade)

  @@unique([eventId, appId])
  @@index([tenantId, appId, createdAt])
  @@index([status, nextRetryAt])
  @@index([tenantId, appId, status])
}

// ============================================================================
// APP BILLING (Per-tenant app usage billing)
// ============================================================================

/// Per-tenant billing configuration. Controls whether billing is active
/// and stores the Stripe customer ID for Bedfront's platform billing
/// (separate from tenant's own Stripe Connect account).
model TenantBillingSettings {
  id                String    @id @default(cuid())
  tenantId          String    @unique
  billingEnabled    Boolean   @default(false) // false = no real charges, just tracking
  stripeCustomerId  String?   // cus_xxx on Bedfront's platform Stripe account
  billingEmail      String?   // override email for invoices
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

/// Monthly billing period. One per tenant per month.
/// Periods are created lazily on first line item.
/// closePeriod() sets status from OPEN to PENDING (ready for invoice)
/// or VOID (if totalAmount === 0).
model TenantBillingPeriod {
  id              String    @id @default(cuid())
  tenantId        String
  periodStart     DateTime  // first day of month 00:00 UTC
  periodEnd       DateTime  // last day of month 23:59:59 UTC
  status          String    @default("OPEN") // OPEN | PENDING | INVOICED | VOID
  totalAmount     Int       @default(0) // sum of line items in ören
  currency        String    @default("SEK")
  stripeInvoiceId String?   // inv_xxx from Stripe — set by generateInvoice()
  closedAt        DateTime?
  invoicedAt      DateTime?

  lineItems       BillingLineItem[]

  @@unique([tenantId, periodStart])
  @@index([tenantId, status])
  @@index([status, periodEnd])
}

/// Individual billing line item within a period.
/// Append-only — never UPDATE, never DELETE. Create new ones for adjustments.
/// Each line represents a charge or credit for an app in a specific period.
model BillingLineItem {
  id          String    @id @default(cuid())
  periodId    String
  tenantId    String
  appId       String     // references AppDefinition.id
  appName     String     // snapshot at creation time — never joins back
  description String     // Swedish: "Google Ads — Grow (15/31 dagar)"
  tier        String     // "free" | "grow" | "pro"
  amount      Int        // in ören (always >= 0). 0 for free tier.
  isProrated  Boolean    @default(false)
  daysInPeriod Int?      // total days in the billing period (for proration display)
  daysCharged  Int?      // days charged in this line item
  createdAt   DateTime   @default(now())

  period      TenantBillingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId])
  @@index([tenantId, appId])
  @@index([tenantId, createdAt])
}

// ============================================================================
// EMAIL MARKETING SYNC
// ============================================================================

enum EmailSyncStatus {
  SYNCED
  PENDING
  FAILED
  UNSUBSCRIBED
}

/// Tracks sync state per contact per provider app per tenant.
/// Upserted on every sync — never creates duplicates.
model EmailMarketingSync {
  id              String          @id @default(cuid())
  tenantId        String
  appId           String
  email           String
  status          EmailSyncStatus
  lastSyncedAt    DateTime        @default(now())
  errorMessage    String?
  contactData     Json

  tenantApp       TenantApp       @relation(fields: [tenantId, appId], references: [tenantId, appId], onDelete: Cascade)

  @@unique([tenantId, appId, email])
  @@index([tenantId, appId])
  @@index([tenantId, status])
}

/// Revenue attribution from email marketing campaigns.
/// Created when order has utm_source matching a marketing provider.
model EmailAttribution {
  id           String   @id @default(cuid())
  tenantId     String
  appId        String
  orderId      String?
  bookingId    String?
  campaignId   String?
  revenue      Int
  attributedAt DateTime @default(now())

  tenantApp    TenantApp @relation(fields: [tenantId, appId], references: [tenantId, appId], onDelete: Cascade)

  @@index([tenantId, appId])
  @@index([tenantId, attributedAt])
  @@index([orderId])
}

// ============================================================================
// GUEST SEGMENTS (Shopify-grade segment engine)
// ============================================================================

/// Segment definition — tenant-scoped, query-driven.
/// Default segments (isDefault=true) are platform-created, not deletable.
/// Custom segments created by merchants via admin UI.
model GuestSegment {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  query       String   @db.Text
  isDefault   Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships GuestSegmentMembership[]
  discountTargets DiscountSegment[]
  emailCampaigns  EmailCampaign[]

  @@index([tenantId])
  @@index([tenantId, isDefault])
}

/// Segment membership — tracks which guests belong to which segments.
/// Soft-delete via leftAt: NULL = active member, non-NULL = left.
/// History preserved: re-joining creates a NEW row (old row keeps leftAt).
model GuestSegmentMembership {
  id             String    @id @default(cuid())
  tenantId       String
  segmentId      String
  guestAccountId String
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?

  segment      GuestSegment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  guestAccount GuestAccount  @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)

  @@unique([segmentId, guestAccountId], name: "segment_guest_active")
  @@index([tenantId, segmentId])
  @@index([tenantId, guestAccountId])
  @@index([segmentId, leftAt])
}

// ============================================================================
// CHECKOUT IDEMPOTENCY
// ============================================================================

enum CheckoutIdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

/// Prevents duplicate checkout requests from creating duplicate orders.
/// Keyed on client-supplied idempotency key + tenant + route type.
/// Rows expire after 24 hours and are cleaned up by cron.
model CheckoutIdempotencyKey {
  id              String                    @id @default(cuid())
  key             String
  tenantId        String
  routeType       String                    // "payment-intent" | "checkout-session"
  status          CheckoutIdempotencyStatus @default(PROCESSING)
  responsePayload Json?
  createdAt       DateTime                  @default(now())
  expiresAt       DateTime                  // 24h TTL

  @@unique([tenantId, key, routeType])
  @@index([expiresAt])
}

// ============================================================================
// RUM ANALYTICS (Real User Monitoring) v2
// ============================================================================

/// Raw RUM events — retained 30 days for accurate P75 calculation.
/// Anonymized: no IP, no UA string, no cookies, no querystrings.
model RumEvent {
  id           String   @id @default(cuid())
  tenantId     String
  lcp          Float?   // ms — only on hard reload
  inp          Float?   // ms — per route
  cls          Float?   // unitless — per route
  sessionId    String   // random UUID per tab, sessionStorage-based, 30min TTL
  deviceType   String   // "desktop" | "mobile" | "tablet" | "other"
  pathname     String   // window.location.pathname, never querystring
  isHardReload Boolean  // true = full page load, false = SPA navigation
  connection   String?  // "4g" | "3g" | "2g" | "slow-2g"
  occurredAt   DateTime
  createdAt    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, sessionId])
  @@index([tenantId, deviceType, createdAt])
}

/// DB-backed rate limiting for beacon endpoint — replaces in-memory Map.
model RumRateLimit {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  count       Int      @default(0)
  windowStart DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Daily RUM aggregates — retained 90 days. Used for trend dashboards.
/// P75 calculated from raw data, not bucket approximation.
model RumDailyAggregate {
  id              String   @id @default(cuid())
  tenantId        String
  date            DateTime @db.Date

  sessions        Int      @default(0)
  sessionsDesktop Int      @default(0)
  sessionsMobile  Int      @default(0)
  sessionsTablet  Int      @default(0)
  sessionsOther   Int      @default(0)

  lcpP75          Float?
  lcpGoodCount    Int      @default(0)
  lcpNeedsWork    Int      @default(0)
  lcpPoor         Int      @default(0)
  lcpCount        Int      @default(0)

  inpP75          Float?
  inpGoodCount    Int      @default(0)
  inpNeedsWork    Int      @default(0)
  inpPoor         Int      @default(0)
  inpCount        Int      @default(0)

  clsP75          Float?
  clsGoodCount    Int      @default(0)
  clsNeedsWork    Int      @default(0)
  clsPoor         Int      @default(0)
  clsCount        Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId, date])
}

// ============================================================================
// ANALYTICS (Behavioral event tracking + pre-aggregated metrics)
// ============================================================================

enum AnalyticsEventType {
  // Session & navigation (frontend)
  SESSION_STARTED
  PAGE_VIEWED
  SESSION_ENDED

  // Accommodation & search (frontend)
  SEARCH_PERFORMED
  ACCOMMODATION_VIEWED
  RATE_PLAN_SELECTED

  // Product & addon (frontend)
  PRODUCT_VIEWED
  ADDON_VIEWED
  ADDON_ADDED
  ADDON_REMOVED

  // Checkout funnel (frontend)
  CHECKOUT_STARTED
  CHECKOUT_COMPLETED
  CHECKOUT_ABANDONED

  // Commerce — server-side only, never emitted from frontend
  ORDER_CREATED
  ORDER_PAID
  ORDER_CANCELLED
  ORDER_REFUNDED
}

enum AnalyticsMetric {
  REVENUE
  SESSIONS
  VISITORS
  ORDERS
  AVERAGE_ORDER_VALUE
  RETURNING_CUSTOMER_RATE
}

enum AnalyticsDimension {
  TOTAL
  CHANNEL
  CITY
  DEVICE
  PRODUCT
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
}

/// Normalized geo — one row per unique city.
/// Events reference this via locationId FK.
model AnalyticsLocation {
  id      String @id @default(cuid())
  country String // ISO 3166-1 alpha-2
  city    String
  lat     Float  // City centroid — never exact visitor position
  lng     Float

  events AnalyticsEvent[]

  @@unique([country, city])
  @@index([country])
}

/// Raw event log — append-only, immutable.
/// Written once. Never updated. Never deleted (except tenant cascade).
model AnalyticsEvent {
  id         String             @id @default(cuid())
  tenantId   String
  sessionId  String
  visitorId  String
  eventType  AnalyticsEventType
  occurredAt DateTime
  receivedAt DateTime           @default(now())

  page      String?
  referrer  String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  deviceType DeviceType @default(DESKTOP)

  locationId String?
  location   AnalyticsLocation? @relation(fields: [locationId], references: [id])

  payload Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, eventType])
  @@index([tenantId, sessionId])
  @@index([tenantId, visitorId])
  @@index([tenantId, occurredAt])
  @@index([tenantId, occurredAt, eventType])
}

/// Pre-aggregated metrics — written by cron.
/// Dashboard reads from here — never from AnalyticsEvent directly.
model AnalyticsDailyMetric {
  id             String             @id @default(cuid())
  tenantId       String
  date           DateTime
  metric         AnalyticsMetric
  dimension      AnalyticsDimension
  dimensionValue String
  value          Int

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, metric, dimension, dimensionValue])
  @@index([tenantId, date])
  @@index([tenantId, metric, date])
  @@index([tenantId, dimension, date])
}

// ── Spot Booking (Platsbokning) ────────────────────────────────

/// Interactive map for spot-based booking. Multiple maps per installation,
/// one per accommodation category.
model SpotMap {
  id                      String   @id @default(cuid())
  tenantId                String
  tenantAppId             String   // FK → TenantApp (the installation)
  accommodationCategoryId String   // FK → AccommodationCategory
  imageUrl                String   // Cloudinary URL
  imagePublicId           String   // Cloudinary public_id (for deletion)
  addonPrice              Int      // fixed surcharge in öre
  currency                String   @default("SEK")
  isActive                Boolean  @default(false) // activated on wizard completion
  draftConfig             Json?    // draft snapshot of desired state (markers + settings)
  draftUpdatedAt          DateTime?
  version                 Int      @default(0) // optimistic lock — incremented on each publish
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantApp             TenantApp             @relation(fields: [tenantAppId], references: [id], onDelete: Cascade)
  accommodationCategory AccommodationCategory @relation(fields: [accommodationCategoryId], references: [id])
  markers               SpotMarker[]

  @@unique([tenantAppId, accommodationCategoryId]) // one map per category per installation
  @@index([tenantId])
  @@index([accommodationCategoryId])
}

/// A bookable spot on a SpotMap — pinned to an Accommodation unit.
model SpotMarker {
  id              String   @id @default(cuid())
  tenantId        String
  spotMapId       String
  accommodationId String   // FK → Accommodation — this is the bookable unit
  label           String   // "32a", "Sjöutsikt" etc
  x               Float    // 0.0–100.0, percentage of image width
  y               Float    // 0.0–100.0, percentage of image height
  priceOverride   Int?     // null = inherit SpotMap.addonPrice; set = override in öre
  color           String?  // null = default accent; set = custom hex e.g. "#e53935"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spotMap       SpotMap       @relation(fields: [spotMapId], references: [id], onDelete: Cascade)
  accommodation Accommodation @relation(fields: [accommodationId], references: [id])

  @@unique([spotMapId, accommodationId]) // one marker per accommodation per map
  @@index([tenantId])
  @@index([spotMapId])
}

// ============================================================================
// EMAIL APP (App Store app — per-tenant marketing email)
// ============================================================================

enum EmailAppStatus {
  ACTIVE
  PAUSED
  UNINSTALLED
}

enum EmailTemplateType {
  CAMPAIGN
  AUTOMATION
  SYSTEM
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
}

enum AutomationTrigger {
  GUEST_CREATED
  ORDER_COMPLETED
  GUEST_INACTIVE
}

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
}

enum SuppressionReason {
  UNSUBSCRIBE
  BOUNCE
  COMPLAINT
  MANUAL
}

model EmailAppInstallation {
  id            String         @id @default(cuid())
  tenantId      String         @unique
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  status        EmailAppStatus
  installedAt   DateTime       @default(now())
  uninstalledAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model EmailAppTemplate {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  name        String
  subject     String
  previewText String?
  blocks      Json
  type        EmailTemplateType
  isArchived  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  campaigns   EmailCampaign[]
  steps       EmailAutomationStep[]

  @@index([tenantId])
}

model EmailCampaign {
  id             String                  @id @default(cuid())
  tenantId       String
  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  templateId     String
  template       EmailAppTemplate        @relation(fields: [templateId], references: [id])
  segmentId      String?
  segment        GuestSegment?           @relation(fields: [segmentId], references: [id])
  status         CampaignStatus
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int                     @default(0)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  recipients     CampaignRecipient[]
  analytics      EmailCampaignAnalytics?

  @@index([tenantId, status])
}

model CampaignRecipient {
  id              String          @id @default(cuid())
  campaignId      String
  campaign        EmailCampaign   @relation(fields: [campaignId], references: [id])
  guestId         String
  guest           GuestAccount    @relation(fields: [guestId], references: [id])
  email           String
  status          RecipientStatus
  resendMessageId String?
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  complainedAt    DateTime?
  unsubscribedAt  DateTime?
  createdAt       DateTime        @default(now())

  @@unique([campaignId, guestId])
  @@index([resendMessageId])
  @@index([campaignId, status])
}

model EmailAutomation {
  id                String                      @id @default(cuid())
  tenantId          String
  tenant            Tenant                      @relation(fields: [tenantId], references: [id])
  name              String
  trigger           AutomationTrigger
  status            AutomationStatus
  allowReenrollment Boolean                     @default(false)
  steps             EmailAutomationStep[]
  enrollments       AutomationEnrollment[]
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  analytics         EmailAutomationAnalytics?

  @@index([tenantId])
}

model EmailAutomationStep {
  id           String          @id @default(cuid())
  automationId String
  automation   EmailAutomation @relation(fields: [automationId], references: [id])
  templateId   String
  template     EmailAppTemplate @relation(fields: [templateId], references: [id])
  delaySeconds Int             @default(0)
  order        Int
  createdAt    DateTime        @default(now())

  enrollments  AutomationEnrollment[]

  @@unique([automationId, order])
}

model AutomationEnrollment {
  id            String               @id @default(cuid())
  tenantId      String
  automationId  String
  automation    EmailAutomation      @relation(fields: [automationId], references: [id])
  guestId       String
  guest         GuestAccount         @relation(fields: [guestId], references: [id])
  currentStepId String?
  currentStep   EmailAutomationStep? @relation(fields: [currentStepId], references: [id])
  scheduledAt   DateTime
  status        EnrollmentStatus
  claimedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([scheduledAt, status])
  @@index([tenantId, automationId])
}

model EmailSuppression {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  email       String
  reason      SuppressionReason
  bounceCount Int               @default(1)
  createdAt   DateTime          @default(now())

  @@unique([tenantId, email])
  @@index([tenantId, email])
}

enum BounceType {
  HARD
  SOFT
}

model EmailBounceEvent {
  id              String     @id @default(cuid())
  tenantId        String
  email           String
  bounceType      BounceType
  resendMessageId String?
  rawPayload      Json
  createdAt       DateTime   @default(now())

  @@index([tenantId, email])
  @@index([createdAt])
}

model EmailCampaignAnalytics {
  campaignId   String        @id
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id])
  sent         Int           @default(0)
  delivered    Int           @default(0)
  opened       Int           @default(0)
  clicked      Int           @default(0)
  bounced      Int           @default(0)
  complained   Int           @default(0)
  unsubscribed Int           @default(0)
  updatedAt    DateTime      @updatedAt
}

model EmailAutomationAnalytics {
  automationId String          @id
  automation   EmailAutomation @relation(fields: [automationId], references: [id])
  sent         Int             @default(0)
  delivered    Int             @default(0)
  opened       Int             @default(0)
  clicked      Int             @default(0)
  bounced      Int             @default(0)
  complained   Int             @default(0)
  unsubscribed Int             @default(0)
  updatedAt    DateTime        @updatedAt
}
